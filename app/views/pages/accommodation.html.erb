<%# Hotel & Homestay (Accommodation) page %>
<% ft       = (@home['footer'] || {})
   ft_links = ft['links'] || []
   vs       = @home['visit'] || {}
   nav      = @home['nav']   || {}
   dd       = nav['discoverDropdown'] || []
   cats     = @page['filterCategories'] || [
     {'label'=>'ALL','value'=>'all'},
     {'label'=>'PRIVATE','value'=>'private'},
     {'label'=>'HOMESTAYS','value'=>'homestays'}
   ]
%>

<%# Sticky HOHO button %>
<div class="sticky-hoho">
  <a href="/hoho">HOHO Service</a>
</div>

<div class="acc-page">

  <%# ── NAVBAR ─────────────────────────────────────────── %>
  <div class="mon-nav-wrap">
    <nav class="hist-navbar">
      <div class="nav-links">
        <div class="nav-discover">
          <a href="/" class="hist-nav-link hist-nav-discover-btn" aria-expanded="false" aria-haspopup="true">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <a href="/plan-your-visit" class="hist-nav-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-link">News</a>
        <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-link">Sabhyata Foundation</a>
      </div>
      <button class="hist-nav-hamburger" id="hist-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-book-btn">Book Tickets</a>
    </nav>

    <div class="hist-nav-mobile-menu" id="hist-nav-mobile-menu">
      <button class="hist-nav-mobile-close" id="hist-nav-mobile-close-btn" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="/" class="nav-mobile-wordmark" aria-label="Home">ORCHHA</a>
      <div class="hist-nav-mobile-links">
        <div class="nav-mobile-group">
          <button type="button" class="hist-nav-mobile-link nav-mobile-group-btn" aria-expanded="false">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="nav-mobile-group-items">
            <% dd.each do |item| %>
            <a href="<%= item['url'] %>" class="hist-nav-mobile-link nav-mobile-sub-link"><%= item['label'] %></a>
            <% end %>
          </div>
        </div>
        <a href="/plan-your-visit" class="hist-nav-mobile-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-mobile-link">News</a>
        <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-mobile-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-mobile-link">Sabhyata Foundation</a>
      </div>
      <div class="nav-mobile-cta-row">
        <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-nav-mobile-book-btn">Book Tickets</a>
        <a href="/hoho" class="hist-nav-mobile-book-btn nav-mobile-hoho-btn">HOHO Service</a>
      </div>
    </div>

    <%# Discover dropdown — kept outside .hist-navbar because its backdrop-filter
        creates a new containing block for position:fixed descendants %>
    <div class="hist-nav-dropdown" role="menu">
      <% dd.each do |item| %>
      <a href="<%= item['url'] %>" class="hist-nav-dropdown-item" role="menuitem"><%= item['label'] %></a>
      <% end %>
    </div>
  </div>

  <%# ── HEADER ─────────────────────────────────────────── %>
  <header class="acc-header">
    <h1 class="acc-heading"><%= @page['heading'] || 'Hotel and Homestay' %></h1>
    <p class="acc-subheading"><%= @page['subheading'] || 'Walk through the corridors of time. Each structure in Orchha tells a unique story of devotion, power, and architectural brilliance.' %></p>
  </header>

  <%# ── ACCOMMODATION SECTION ────────────────────────────── %>
  <section class="acc-section">

    <%# Filter row %>
    <div class="acc-filter-row">
      <div class="acc-filter-tabs" role="tablist">
        <% cats.each_with_index do |cat, i| %>
        <button class="acc-tab <%= i == 0 ? 'active' : '' %>"
                data-cat="<%= cat['value'] %>"
                role="tab"
                aria-selected="<%= i == 0 ? 'true' : 'false' %>">
          <%= cat['label'] %>
        </button>
        <% end %>
      </div>
      <div class="acc-search">
        <input class="acc-search-input" type="text" id="acc-search-input" placeholder="Search...">
        <svg class="acc-search-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="9" cy="9" r="6" stroke="#6e1603" stroke-width="2"/>
          <path d="M13.5 13.5L17 17" stroke="#6e1603" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
    </div>

    <%# Cards grid %>
    <div class="acc-cards" id="acc-cards">
      <% @items.each do |h| %>
      <div class="acc-card"
           data-cat="<%= h['category'] || 'private' %>"
           data-name="<%= h['name'].downcase %>">
        <div class="acc-card-photo">
          <img src="<%= h['image'] %>" alt="<%= h['name'] %>" loading="lazy">
          <div class="acc-card-photo-overlay"></div>
          <div class="acc-card-logos">
            <img src="/images/mpt_logo.png" class="acc-logo-mpt" alt="MPT">
            <img src="/images/incredible_india.png" class="acc-logo-ii" alt="Incredible India">
          </div>
          <h3 class="acc-card-name"><%= h['name'] %></h3>
        </div>
        <div class="acc-card-body">
          <div class="acc-card-rating">
            <span class="acc-card-rating-num"><%= format('%.1f', h['rating'] || 0) %></span>
            <% full = (h['rating'] || 0).to_i %>
            <% 5.times do |i| %>
              <svg viewBox="0 0 20 20" fill="<%= i < full ? '#fff' : 'none' %>" stroke="#fff" stroke-width="1.2">
                <path d="M10 1.5l2.47 5.27 5.53.6-4.1 4.02 1.06 5.6L10 14.2l-4.96 2.79 1.06-5.6-4.1-4.02 5.53-.6L10 1.5z"/>
              </svg>
            <% end %>
          </div>
          <div class="acc-card-contact">
            <div class="acc-card-contact-row">
              <svg viewBox="0 0 20 20" fill="none"><path d="M4 3h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5v3a1.5 1.5 0 0 1-1.6 1.5A15 15 0 0 1 2.5 4.6 1.5 1.5 0 0 1 4 3z" stroke="#fff" stroke-width="1.3" stroke-linejoin="round"/></svg>
              <span><%= h['phone'] %></span>
            </div>
            <% if h['email'].present? %>
            <div class="acc-card-contact-row">
              <svg viewBox="0 0 20 20" fill="none"><rect x="2.5" y="4.5" width="15" height="11" rx="1.5" stroke="#fff" stroke-width="1.3"/><path d="M3 5.5l7 5.5 7-5.5" stroke="#fff" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><%= h['email'] %></span>
            </div>
            <% end %>
            <div class="acc-card-contact-row">
              <svg viewBox="0 0 20 20" fill="none"><path d="M10 18s6-5.5 6-10a6 6 0 0 0-12 0c0 4.5 6 10 6 10z" stroke="#fff" stroke-width="1.3" stroke-linejoin="round"/><circle cx="10" cy="8" r="2" stroke="#fff" stroke-width="1.3"/></svg>
              <span><%= h['address'] %></span>
            </div>
          </div>
          <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="acc-book-btn">Book Now</a>
        </div>
      </div>
      <% end %>
    </div>

    <%# Empty state %>
    <p class="acc-empty" id="acc-empty" style="display:none">No accommodations found.</p>

  </section>

  <%# ── VISIT ORCHHA (reused) ──────────────────────────── %>
  <div class="visit-wrap">
    <div class="visit-section">
      <div class="visit-bg-img" style="background-image: url('<%= vs['bgImage'] || '/images/visit_orchha_bg.jpg' %>')"></div>
      <div class="visit-content">
        <h2 class="visit-heading"><em>Visit</em> Orchha</h2>
        <div class="visit-links">
          <% (vs['links'] || [{'label'=>'How to Reach Orchha','url'=>'/reach'},{'label'=>'Travel Options','url'=>'/travel'},{'label'=>'Stay Options','url'=>'/stay'}]).each do |lnk| %>
          <a href="<%= lnk['url'] %>" class="visit-link"><%= lnk['label'] %></a>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── FOOTER ─────────────────────────────────────────── %>
<%= render 'shared/footer', ft: ft %>

</div><%# /.acc-page %>

<script>
  // ── Navbar dropdown ───────────────────────────────────────
  const accBtn = document.querySelector('.hist-nav-discover-btn');
  const accDd  = document.querySelector('.hist-nav-dropdown');
  if (accBtn && accDd) {
    let accDdCloseTimer;
    function openAccDd() {
      clearTimeout(accDdCloseTimer);
      const r = accBtn.getBoundingClientRect();
      accDd.style.top  = (r.bottom + 8) + 'px';
      accDd.style.left = r.left + 'px';
      accDd.classList.add('open');
      accBtn.classList.add('open');
      accBtn.setAttribute('aria-expanded', 'true');
    }
    function closeAccDd() {
      accDd.classList.remove('open');
      accBtn.classList.remove('open');
      accBtn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseAccDd() { accDdCloseTimer = setTimeout(closeAccDd, 200); }
    accBtn.addEventListener('mouseenter', openAccDd);
    accBtn.addEventListener('mouseleave', scheduleCloseAccDd);
    accDd.addEventListener('mouseenter', () => clearTimeout(accDdCloseTimer));
    accDd.addEventListener('mouseleave', scheduleCloseAccDd);
    accBtn.addEventListener('click', e => { if (accDd.classList.contains('open')) return; e.preventDefault(); openAccDd(); });
    document.addEventListener('click', closeAccDd);
    accDd.addEventListener('click', e => e.stopPropagation());
  }

  // ── Mobile hamburger menu ───────────────────────────────────
  const histHamburgerBtn = document.getElementById('hist-nav-hamburger-btn');
  const histMobileMenu   = document.getElementById('hist-nav-mobile-menu');
  const histMobileClose  = document.getElementById('hist-nav-mobile-close-btn');
  if (histHamburgerBtn && histMobileMenu) {
    function openHistMobileMenu() {
      histMobileMenu.classList.add('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeHistMobileMenu() {
      histMobileMenu.classList.remove('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    histHamburgerBtn.addEventListener('click', openHistMobileMenu);
    if (histMobileClose) histMobileClose.addEventListener('click', closeHistMobileMenu);
    histMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeHistMobileMenu));
  }

  // ── Filter + Search ───────────────────────────────────────
  const accCards = Array.from(document.querySelectorAll('.acc-card'));
  const accTabs  = Array.from(document.querySelectorAll('.acc-tab'));
  const accEmpty = document.getElementById('acc-empty');
  let accActiveCat = 'all';
  let accSearchVal = '';

  function applyAccFilter() {
    let visible = 0;
    accCards.forEach(card => {
      const cat  = card.dataset.cat;
      const name = card.dataset.name;
      const catOk  = accActiveCat === 'all' || cat === accActiveCat;
      const nameOk = name.includes(accSearchVal.toLowerCase());
      const show = catOk && nameOk;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    accEmpty.style.display = visible === 0 ? 'block' : 'none';
  }

  accTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      accTabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected','true');
      accActiveCat = tab.dataset.cat;
      applyAccFilter();
    });
  });

  document.getElementById('acc-search-input').addEventListener('input', e => {
    accSearchVal = e.target.value;
    applyAccFilter();
  });
</script>
