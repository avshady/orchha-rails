<%# Light & Sound Show page %>
<% nav = (@home['nav'] || {})
   dd  = nav['discoverDropdown'] || []
   p   = @page
   times   = p['showTimes'] || {}
   summer  = times['summer'] || {}
   winter  = times['winter'] || {}
   pricing = p['pricing'] || {}
   guidelines = p['guidelines'] || []
   gallery    = p['gallery'] || []
%>

<div class="sticky-hoho"><a href="/hoho">HOHO Service</a></div>

<div class="lss-page">

  <%# ── NAVBAR ─────────────────────────────────────────── %>
  <div class="mon-nav-wrap">
    <nav class="hist-navbar">
      <div class="nav-links">
        <div class="nav-discover">
          <a href="/" class="hist-nav-link hist-nav-discover-btn" aria-expanded="false" aria-haspopup="true">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <a href="/plan-your-visit" class="hist-nav-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-link">News</a>
        <a href="/support-us" class="hist-nav-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-link">Sabhyata Foundation</a>
      </div>
      <button class="hist-nav-hamburger" id="hist-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-book-btn">Book Tickets</a>
    </nav>

    <div class="hist-nav-mobile-menu" id="hist-nav-mobile-menu">
      <button class="hist-nav-mobile-close" id="hist-nav-mobile-close-btn" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="hist-nav-mobile-links">
        <% dd.each do |item| %>
        <a href="<%= item['url'] %>" class="hist-nav-mobile-link"><%= item['label'] %></a>
        <% end %>
        <a href="/plan-your-visit" class="hist-nav-mobile-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-mobile-link">News</a>
        <a href="/support-us" class="hist-nav-mobile-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-mobile-link">Sabhyata Foundation</a>
      </div>
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-nav-mobile-book-btn">Book Tickets</a>
    </div>

    <div class="hist-nav-dropdown" role="menu">
      <% dd.each do |item| %>
      <a href="<%= item['url'] %>" class="hist-nav-dropdown-item" role="menuitem"><%= item['label'] %></a>
      <% end %>
    </div>
  </div>

  <div class="lss-layout">
    <div class="lss-main">

      <%# ── HERO ROW: photo card + heading/description/book ───── %>
      <section class="lss-hero-row">
        <div class="lss-hero-card">
          <img src="<%= p['heroImage'] || '/images/lss_hero.jpg' %>" alt="Orchha Fort illuminated at night">
          <div class="lss-hero-card-gradient"></div>
          <div class="lss-hero-feature-row">
            <div class="lss-hero-feature">
              <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 8a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-5l-4 3v-3H7a2 2 0 0 1-2-2V8Z" stroke="#d0a259" stroke-width="1.6" stroke-linejoin="round"/><path d="M21 10h1a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-1v3l-4-3h-4" stroke="#d0a259" stroke-width="1.6" stroke-linejoin="round"/></svg>
              <div><span class="lss-feature-label">Languages</span><span class="lss-feature-value"><%= p['languages'] || 'English & Hindi' %></span></div>
            </div>
            <span class="lss-feature-divider"></span>
            <div class="lss-hero-feature">
              <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="14" cy="14" r="10" stroke="#d0a259" stroke-width="1.6"/><path d="M14 8v6l4 2.5" stroke="#d0a259" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <div><span class="lss-feature-label">Duration</span><span class="lss-feature-value"><%= p['duration'] || '~1 Hour' %></span></div>
            </div>
            <span class="lss-feature-divider"></span>
            <div class="lss-hero-feature">
              <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4 24V11l10-6 10 6v13" stroke="#d0a259" stroke-width="1.6" stroke-linejoin="round"/><path d="M8 24v-8h12v8M12 24v-5h4v5" stroke="#d0a259" stroke-width="1.6" stroke-linejoin="round"/></svg>
              <div><span class="lss-feature-label">Venue</span><span class="lss-feature-value"><%= p['venue'] || 'Near Jehangir Mahal' %></span></div>
            </div>
            <span class="lss-feature-divider"></span>
            <div class="lss-hero-feature">
              <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="10" cy="10" r="3.4" stroke="#d0a259" stroke-width="1.6"/><path d="M3.5 22c0-4 3-6.6 6.5-6.6s6.5 2.6 6.5 6.6" stroke="#d0a259" stroke-width="1.6" stroke-linecap="round"/><circle cx="19" cy="9" r="2.7" stroke="#d0a259" stroke-width="1.6"/><path d="M17.5 15.6c2.8.4 5 2.8 5 6.4" stroke="#d0a259" stroke-width="1.6" stroke-linecap="round"/></svg>
              <div><span class="lss-feature-label">Capacity</span><span class="lss-feature-value"><%= p['capacity'] || '150 - 200' %></span></div>
            </div>
          </div>
        </div>

        <div class="lss-hero-text">
          <h1 class="lss-heading"><%= p['heading'] || 'Light & Sound Show' %></h1>
          <p class="lss-description"><%= p['description'] %></p>
          <div class="lss-heading-rule"></div>
          <a href="<%= p['bookUrl'].presence || 'https://www.tezticket.com/tickets/buy?event=SF' %>" target="_blank" rel="noopener" class="lss-book-btn">
            Book Tickets
            <svg viewBox="0 0 24 10" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 5h20M16 1l4 4-4 4" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </section>

      <%# ── INFO GRID: show times/pricing | visitor guideline | gallery ──── %>
      <section class="lss-info-grid">

        <div class="lss-col lss-col-times">
          <h2 class="lss-col-heading">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="16" cy="16" r="12" stroke="#6e1603" stroke-width="1.8"/><path d="M16 9v7l5 3" stroke="#6e1603" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Show times
          </h2>
          <div class="lss-card lss-times-card">
            <div class="lss-times-col">
              <div class="lss-times-title">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="6" stroke="#6e1603" stroke-width="1.6"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/></svg>
                <span><%= summer['label'] || 'Summer Time' %></span>
              </div>
              <div class="lss-times-row">
                <span class="lss-times-lang">English</span>
                <span class="lss-times-hrs"><%= summer['english'] %></span>
              </div>
              <div class="lss-times-row">
                <span class="lss-times-lang">Hindi</span>
                <span class="lss-times-hrs"><%= summer['hindi'] %></span>
              </div>
            </div>
            <span class="lss-times-sep"></span>
            <div class="lss-times-col">
              <div class="lss-times-title">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2v20M4 7l16 10M20 7 4 17M2 12h20" stroke="#6e1603" stroke-width="1.4" stroke-linecap="round"/></svg>
                <span><%= winter['label'] || 'Winter Time' %></span>
              </div>
              <div class="lss-times-row">
                <span class="lss-times-lang">English</span>
                <span class="lss-times-hrs"><%= winter['english'] %></span>
              </div>
              <div class="lss-times-row">
                <span class="lss-times-lang">Hindi</span>
                <span class="lss-times-hrs"><%= winter['hindi'] %></span>
              </div>
            </div>
          </div>

          <h2 class="lss-col-heading lss-pricing-heading">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="9" width="24" height="14" rx="2" stroke="#6e1603" stroke-width="1.8"/><circle cx="16" cy="16" r="3.5" stroke="#6e1603" stroke-width="1.8"/></svg>
            Ticket Pricing
          </h2>
          <div class="lss-card lss-pricing-card">
            <div class="lss-price-col">
              <svg viewBox="0 0 46 46" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="23" cy="23" r="21" fill="#f5730a"/><circle cx="23" cy="23" r="21" fill="#fff" fill-opacity="0" /><rect x="2" y="9" width="42" height="9.3" fill="#ff9933"/><rect x="2" y="18.3" width="42" height="9.3" fill="#fff"/><rect x="2" y="27.7" width="42" height="9.3" fill="#128807"/><circle cx="23" cy="23" r="4" stroke="#000088" stroke-width="1"/></svg>
              <p class="lss-price-label">Indian Nationals</p>
              <p class="lss-price-sub">Per person</p>
              <p class="lss-price-value"><%= pricing['indian'] || '₹500' %></p>
            </div>
            <span class="lss-times-sep"></span>
            <div class="lss-price-col">
              <svg viewBox="0 0 46 46" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="23" cy="23" r="21" stroke="#6e1603" stroke-width="1.8"/><path d="M2 23h42M23 2c5 5.5 5 34.5 0 42M23 2c-5 5.5-5 34.5 0 42" stroke="#6e1603" stroke-width="1.6"/></svg>
              <p class="lss-price-label">Foreign Nationals</p>
              <p class="lss-price-sub">Per person</p>
              <p class="lss-price-value"><%= pricing['foreign'] || '₹750' %></p>
            </div>
          </div>
          <div class="lss-card lss-admission-card">
            <p><%= pricing['note1'] || 'General admission' %></p>
            <p><%= pricing['note2'] || 'Open-air venue' %></p>
            <p><%= pricing['note3'] || 'No assigned seating' %></p>
          </div>
        </div>

        <div class="lss-col lss-col-guideline">
          <h2 class="lss-col-heading lss-guideline-heading">Visitor<br>Guideline</h2>
          <ul class="lss-guideline-list">
            <% icons = [
                 '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9" stroke="#6e1603" stroke-width="1.6"/><path d="M12 7v5l3.5 2" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
                 '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="4" width="16" height="16" rx="2" stroke="#6e1603" stroke-width="1.6"/><path d="M8 2v4M16 2v4M4 10h16" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/><path d="m9.5 15 2 2 3.5-4" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
                 '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 3v8a2 2 0 0 0 2 2v8M6 3v6M9 3v6M6 9h3M15 3c-2 2-2 4-2 6a2 2 0 0 0 2 2v10" stroke="#6e1603" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 21 21 3" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/></svg>',
                 '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 6a3 3 0 0 1 6 0v6a3 3 0 0 1-6 0V6Z" stroke="#6e1603" stroke-width="1.6"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/><path d="M3 21 21 3" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/></svg>',
                 '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13 16V8l-5 4H4v0h4l5 4Z" stroke="#6e1603" stroke-width="1.6" stroke-linejoin="round"/><path d="M17 9a4 4 0 0 1 0 6" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/><path d="M3 21 21 3" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/></svg>',
                 '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="6" width="18" height="12" rx="2" stroke="#6e1603" stroke-width="1.6"/><path d="M3 10h18M7 14h4" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/></svg>'
               ] %>
            <% guidelines.each_with_index do |g, i| %>
            <li class="lss-guideline-item">
              <span class="lss-guideline-icon"><%= raw(icons[i % icons.length]) %></span>
              <span><%= g %></span>
            </li>
            <% end %>
          </ul>
        </div>

        <div class="lss-col lss-col-gallery">
          <h2 class="lss-gallery-heading">Glimpse of Experience</h2>
          <div class="lss-gallery-grid">
            <% gallery.each do |img| %>
            <div class="lss-gallery-tile"><img src="<%= img %>" alt="Light and Sound Show" loading="lazy"></div>
            <% end %>
          </div>
        </div>

      </section>
    </div><%# /.lss-main %>

    <div class="lss-side-image">
      <img src="<%= p['sideImage'] || '/images/lss_side.jpg' %>" alt="Orchha Fort illuminated at night">
      <div class="lss-side-overlay"></div>
      <a href="/experiences" class="lss-side-cta">View All Experiences &amp; Trails</a>
    </div>
  </div><%# /.lss-layout %>

</div><%# /.lss-page %>

<script>
  const lssBtn = document.querySelector('.hist-nav-discover-btn');
  const lssDd  = document.querySelector('.hist-nav-dropdown');
  if (lssBtn && lssDd) {
    let lssCloseTimer;
    function openLssDd() {
      clearTimeout(lssCloseTimer);
      const r = lssBtn.getBoundingClientRect();
      lssDd.style.top  = (r.bottom + 8) + 'px';
      lssDd.style.left = r.left + 'px';
      lssDd.classList.add('open');
      lssBtn.classList.add('open');
      lssBtn.setAttribute('aria-expanded', 'true');
    }
    function closeLssDd() {
      lssDd.classList.remove('open');
      lssBtn.classList.remove('open');
      lssBtn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseLssDd() { lssCloseTimer = setTimeout(closeLssDd, 200); }
    lssBtn.addEventListener('mouseenter', openLssDd);
    lssBtn.addEventListener('mouseleave', scheduleCloseLssDd);
    lssDd.addEventListener('mouseenter', () => clearTimeout(lssCloseTimer));
    lssDd.addEventListener('mouseleave', scheduleCloseLssDd);
    lssBtn.addEventListener('click', e => { if (lssDd.classList.contains('open')) return; e.preventDefault(); openLssDd(); });
    document.addEventListener('click', closeLssDd);
    lssDd.addEventListener('click', e => e.stopPropagation());
  }

  const histHamburgerBtn = document.getElementById('hist-nav-hamburger-btn');
  const histMobileMenu   = document.getElementById('hist-nav-mobile-menu');
  const histMobileClose  = document.getElementById('hist-nav-mobile-close-btn');
  if (histHamburgerBtn && histMobileMenu) {
    function openHistMobileMenu() {
      histMobileMenu.classList.add('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeHistMobileMenu() {
      histMobileMenu.classList.remove('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    histHamburgerBtn.addEventListener('click', openHistMobileMenu);
    if (histMobileClose) histMobileClose.addEventListener('click', closeHistMobileMenu);
    histMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeHistMobileMenu));
  }
</script>
