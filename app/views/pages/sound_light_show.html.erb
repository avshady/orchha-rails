<%# Light & Sound Show — horizontal scroll-jack matching the Figma frame
    (4648x818): content strip (222.78vw, positions from Figma) + outro. %>
<% nav = (@home['nav'] || {})
   dd  = nav['discoverDropdown'] || []
   p   = @page
   times   = p['showTimes'] || {}
   summer  = times['summer'] || {}
   winter  = times['winter'] || {}
   pricing = p['pricing'] || {}
   guidelines = p['guidelines'] || []
   gallery    = p['gallery'] || []
%>

<div class="sticky-hoho"><a href="/hoho">HOHO Service</a></div>

<%# Fixed light nav (Figma uses the maroon-on-beige nav variant) %>
<div class="lss-nav-fixed">
  <div class="mon-nav-wrap">
    <nav class="hist-navbar">
      <div class="nav-links">
        <div class="nav-discover">
          <a href="/" class="hist-nav-link hist-nav-discover-btn" aria-expanded="false" aria-haspopup="true">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <a href="/plan-your-visit" class="hist-nav-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-link">News</a>
        <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-link">Sabhyata Foundation</a>
      </div>
      <button class="hist-nav-hamburger" id="hist-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-book-btn">Book Tickets</a>
    </nav>

    <div class="hist-nav-mobile-menu" id="hist-nav-mobile-menu">
      <button class="hist-nav-mobile-close" id="hist-nav-mobile-close-btn" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="hist-nav-mobile-links">
        <a href="/" class="hist-nav-mobile-link">Home</a>
        <% dd.each do |item| %>
        <a href="<%= item['url'] %>" class="hist-nav-mobile-link"><%= item['label'] %></a>
        <% end %>
        <a href="/plan-your-visit" class="hist-nav-mobile-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-mobile-link">News</a>
        <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-mobile-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-mobile-link">Sabhyata Foundation</a>
      </div>
      <div class="nav-mobile-cta-row">
        <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-nav-mobile-book-btn">Book Tickets</a>
        <a href="/hoho" class="hist-nav-mobile-book-btn nav-mobile-hoho-btn">HOHO Service</a>
      </div>
    </div>

    <%# Discover dropdown — kept outside .hist-navbar because its backdrop-filter
        creates a new containing block for position:fixed descendants %>
    <div class="hist-nav-dropdown" role="menu">
      <% dd.each do |item| %>
      <a href="<%= item['url'] %>" class="hist-nav-dropdown-item" role="menuitem"><%= item['label'] %></a>
      <% end %>
    </div>
  </div>
</div>

<div class="mdet-wrapper lss-wrapper" data-panels="3.23">
  <div class="mdet-sticky">
    <div class="mdet-track" id="mdet-track">

      <%# ══ PANEL 1 — CONTENT STRIP (222.78vw, positions from Figma) ══ %>
      <section class="mdet-panel lss-strip">

        <%# Hero photo card (Figma x120 y172 631x564) %>
        <div class="lss-hero-card">
          <%= render 'hero_media', config: p, fallback: '/images/lss_hero.jpg', alt: 'Orchha Fort illuminated at night' %>
          <div class="lss-hero-card-gradient"></div>
          <div class="lss-hero-feature-row">
            <div class="lss-hero-feature">
              <div><span class="lss-feature-label">Languages</span><span class="lss-feature-value"><%= p['languages'] || 'English & Hindi' %></span></div>
            </div>
            <span class="lss-feature-divider"></span>
            <div class="lss-hero-feature">
              <div><span class="lss-feature-label">Duration</span><span class="lss-feature-value"><%= p['duration'] || '~1 Hour' %></span></div>
            </div>
            <span class="lss-feature-divider"></span>
            <div class="lss-hero-feature">
              <div><span class="lss-feature-label">Venue</span><span class="lss-feature-value"><%= p['venue'] || 'Near Jehangir Mahal' %></span></div>
            </div>
            <span class="lss-feature-divider"></span>
            <div class="lss-hero-feature">
              <div><span class="lss-feature-label">Capacity</span><span class="lss-feature-value"><%= p['capacity'] || '150 - 200' %></span></div>
            </div>
          </div>
        </div>

        <%# Heading column (Figma x776 y183) %>
        <h1 class="lss-heading"><%= p['heading'] || 'Light & Sound Show' %></h1>
        <div class="lss-desc-col">
          <p class="lss-description"><%= p['description'] %></p>
          <a href="<%= p['bookUrl'].presence || 'https://www.tezticket.com/tickets/buy?event=SF' %>" target="_blank" rel="noopener" class="lss-book-btn">Book Tickets</a>
        </div>

        <%# Show times column (Figma x1321 y160) %>
        <h2 class="lss-col-heading lss-times-heading">Show times</h2>
        <div class="lss-card lss-times-card">
          <div class="lss-times-col">
            <div class="lss-times-title">
              <span><%= summer['label'] || 'Summer Time' %></span>
            </div>
            <div class="lss-times-row">
              <span class="lss-times-lang">English</span>
              <span class="lss-times-hrs"><%= summer['english'] %></span>
            </div>
            <div class="lss-times-row">
              <span class="lss-times-lang">Hindi</span>
              <span class="lss-times-hrs"><%= summer['hindi'] %></span>
            </div>
          </div>
          <span class="lss-times-sep"></span>
          <div class="lss-times-col">
            <div class="lss-times-title">
              <span><%= winter['label'] || 'Winter Time' %></span>
            </div>
            <div class="lss-times-row">
              <span class="lss-times-lang">English</span>
              <span class="lss-times-hrs"><%= winter['english'] %></span>
            </div>
            <div class="lss-times-row">
              <span class="lss-times-lang">Hindi</span>
              <span class="lss-times-hrs"><%= winter['hindi'] %></span>
            </div>
          </div>
        </div>

        <h2 class="lss-col-heading lss-pricing-heading">Ticket Pricing</h2>
        <div class="lss-card lss-pricing-card">
          <div class="lss-price-col">
            <p class="lss-price-label">Indian Nationals</p>
            <p class="lss-price-value"><%= pricing['indian'] || '₹500' %></p>
            <p class="lss-price-sub">Per person</p>
          </div>
          <span class="lss-times-sep"></span>
          <div class="lss-price-col">
            <p class="lss-price-label">Foreign Nationals</p>
            <p class="lss-price-value"><%= pricing['foreign'] || '₹750' %></p>
            <p class="lss-price-sub">Per person</p>
          </div>
        </div>
        <div class="lss-card lss-admission-card">
          <p><%= pricing['note1'] || 'General admission' %></p>
          <p><%= pricing['note2'] || 'Open-air venue' %></p>
          <p><%= pricing['note3'] || 'No assigned seating' %></p>
        </div>

        <%# Visitor Guideline column (Figma x1847 y154) %>
        <div class="lss-guideline-block">
          <h2 class="lss-guideline-heading">Visitor<br>Guideline</h2>
          <ul class="lss-guideline-list">
            <% guidelines.each do |g| %>
            <li class="lss-guideline-item"><span><%= g %></span></li>
            <% end %>
          </ul>
        </div>

        <%# Gallery carousel (Figma x2314 y132) %>
        <h2 class="lss-gallery-heading">Glimpse of Experience</h2>
        <div class="lss-carousel" id="lss-carousel">
          <% gallery.each_with_index do |img, i| %>
          <div class="lss-carousel-slide <%= 'is-active' if i.zero? %>"><img src="<%= img %>" alt="Light and Sound Show" loading="<%= i.zero? ? 'eager' : 'lazy' %>"></div>
          <% end %>
          <% if gallery.length > 1 %>
          <button type="button" class="lss-car-btn lss-car-prev" aria-label="Previous photo">&#8249;</button>
          <button type="button" class="lss-car-btn lss-car-next" aria-label="Next photo">&#8250;</button>
          <div class="lss-car-dots" aria-hidden="true">
            <% gallery.each_with_index do |_, i| %>
            <span class="<%= 'is-active' if i.zero? %>"></span>
            <% end %>
          </div>
          <% end %>
        </div>

        <div class="mdet-scroll-hint lss-scroll-hint" id="mdet-scroll-hint">
          <span>Scroll to explore</span>
          <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

      </section><%# /lss-strip %>

      <%# ══ PANEL 2 — OUTRO (full-bleed night photo + CTA) ═══════════ %>
      <section class="mdet-panel lss-outro-panel">
        <img src="<%= p['sideImage'] || '/images/lss_side.jpg' %>" class="lss-outro-bg" alt="Orchha Fort illuminated during the show">
        <div class="lss-outro-overlay"></div>
        <a href="/experiences" class="lss-outro-cta">View All Experiences &amp; Walks</a>
      </section>

    </div><%# /mdet-track %>
  </div><%# /mdet-sticky %>
</div><%# /mdet-wrapper %>

<script>
(function() {
  const isMobile = window.matchMedia('(max-width: 900px)').matches;

  const wrapper = document.querySelector('.lss-wrapper');
  const sticky  = document.querySelector('.mdet-sticky');
  const hint    = document.getElementById('mdet-scroll-hint');

  if (wrapper && sticky && !isMobile) {
    const panels = parseFloat(wrapper.dataset.panels || '3.23');
    wrapper.style.height = (panels * 100) + 'vh';

    function updateHoriz() {
      const wrapperTop  = wrapper.offsetTop;
      const totalScroll = wrapper.offsetHeight - window.innerHeight;
      const progress    = Math.max(0, Math.min(1, (window.scrollY - wrapperTop) / totalScroll));
      const maxScroll   = sticky.scrollWidth - window.innerWidth;
      sticky.scrollLeft = progress * maxScroll;
      if (hint) hint.style.opacity = progress > 0.01 ? '0' : '1';
    }

    window.addEventListener('scroll', updateHoriz, { passive: true });
    updateHoriz();
  }

  const navBtn = document.querySelector('.hist-nav-discover-btn');
  const navDd  = document.querySelector('.hist-nav-dropdown');
  if (navBtn && navDd) {
    let navDdCloseTimer;
    function openDd() {
      clearTimeout(navDdCloseTimer);
      const r = navBtn.getBoundingClientRect();
      navDd.style.top  = (r.bottom + 8) + 'px';
      navDd.style.left = r.left + 'px';
      navDd.classList.add('open');
      navBtn.classList.add('open');
      navBtn.setAttribute('aria-expanded', 'true');
    }
    function closeDd() {
      navDd.classList.remove('open');
      navBtn.classList.remove('open');
      navBtn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseDd() { navDdCloseTimer = setTimeout(closeDd, 200); }
    navBtn.addEventListener('mouseenter', openDd);
    navBtn.addEventListener('mouseleave', scheduleCloseDd);
    navDd.addEventListener('mouseenter', () => clearTimeout(navDdCloseTimer));
    navDd.addEventListener('mouseleave', scheduleCloseDd);
    navBtn.addEventListener('click', e => { if (navDd.classList.contains('open')) return; e.preventDefault(); openDd(); });
    document.addEventListener('click', closeDd);
    navDd.addEventListener('click', e => e.stopPropagation());
  }

  // ── Mobile hamburger menu ─────────────────────────────────
  const histHamburgerBtn = document.getElementById('hist-nav-hamburger-btn');
  const histMobileMenu   = document.getElementById('hist-nav-mobile-menu');
  const histMobileClose  = document.getElementById('hist-nav-mobile-close-btn');
  if (histHamburgerBtn && histMobileMenu) {
    function openHistMobileMenu() {
      histMobileMenu.classList.add('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeHistMobileMenu() {
      histMobileMenu.classList.remove('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    histHamburgerBtn.addEventListener('click', openHistMobileMenu);
    if (histMobileClose) histMobileClose.addEventListener('click', closeHistMobileMenu);
    histMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeHistMobileMenu));
  }

  // ── "Glimpse of Experience" carousel ──────────────────────
  const carousel = document.getElementById('lss-carousel');
  if (carousel) {
    const slides = Array.from(carousel.querySelectorAll('.lss-carousel-slide'));
    const dots   = Array.from(carousel.querySelectorAll('.lss-car-dots span'));
    if (slides.length > 1) {
      let current = 0, timer = null;
      function goTo(i) {
        current = (i + slides.length) % slides.length;
        slides.forEach((s, j) => s.classList.toggle('is-active', j === current));
        dots.forEach((d, j) => d.classList.toggle('is-active', j === current));
      }
      function restart() {
        clearInterval(timer);
        timer = setInterval(() => goTo(current + 1), 4500);
      }
      carousel.querySelector('.lss-car-prev').addEventListener('click', () => { goTo(current - 1); restart(); });
      carousel.querySelector('.lss-car-next').addEventListener('click', () => { goTo(current + 1); restart(); });
      carousel.addEventListener('mouseenter', () => clearInterval(timer));
      carousel.addEventListener('mouseleave', restart);
      restart();
    }
  }
})();
</script>
