<%# Art of Orchha / Frescoes — gallery grid of palace & temple murals %>
<% ft       = (@home['footer'] || {})
   ft_links = ft['links'] || []
   nav      = @home['nav']   || {}
   dd       = nav['discoverDropdown'] || []
   vs       = @home['visit'] || {}
   items    = @items.presence || []
   cats     = @page['filterCategories'] || [
     {'label'=>'All','value'=>'all'},
     {'label'=>'Lakshmi Narayan Temple','value'=>'lakshmi-narayan-temple'},
     {'label'=>'Raja Mahal','value'=>'raja-mahal'}
   ]
%>

<%# Sticky HOHO button %>
<div class="sticky-hoho">
  <a href="/hoho">HOHO Service</a>
</div>

<div class="aof-page">

  <%# ── NAVBAR ─────────────────────────────────────────── %>
  <div class="mon-nav-wrap">
    <nav class="hist-navbar">
      <div class="nav-links">
        <div class="nav-discover">
          <a href="/" class="hist-nav-link hist-nav-discover-btn" aria-expanded="false" aria-haspopup="true">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <a href="/plan-your-visit" class="hist-nav-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-link">News</a>
        <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-link">Sabhyata Foundation</a>
      </div>
      <button class="hist-nav-hamburger" id="hist-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-book-btn">Book Tickets</a>
    </nav>

    <div class="hist-nav-mobile-menu" id="hist-nav-mobile-menu">
      <button class="hist-nav-mobile-close" id="hist-nav-mobile-close-btn" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="hist-nav-mobile-links">
        <a href="/" class="hist-nav-mobile-link">Home</a>
        <% dd.each do |item| %>
        <a href="<%= item['url'] %>" class="hist-nav-mobile-link"><%= item['label'] %></a>
        <% end %>
        <a href="/plan-your-visit" class="hist-nav-mobile-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-mobile-link">News</a>
        <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-mobile-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-mobile-link">Sabhyata Foundation</a>
      </div>
      <div class="nav-mobile-cta-row">
        <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-nav-mobile-book-btn">Book Tickets</a>
        <a href="/hoho" class="hist-nav-mobile-book-btn nav-mobile-hoho-btn">HOHO Service</a>
      </div>
    </div>

    <%# Discover dropdown — kept outside .hist-navbar because its backdrop-filter
        creates a new containing block for position:fixed descendants %>
    <div class="hist-nav-dropdown" role="menu">
      <% dd.each do |item| %>
      <a href="<%= item['url'] %>" class="hist-nav-dropdown-item" role="menuitem"><%= item['label'] %></a>
      <% end %>
    </div>
  </div>

  <%# ── HEADER ─────────────────────────────────────────── %>
  <header class="aof-header">
    <h1 class="aof-heading"><%= @page['heading'] || 'Art of Orchha / Frescoes' %></h1>
  </header>

  <%# ── GALLERY ────────────────────────────────────────── %>
  <section class="aof-section">
    <div class="evt-filter-tabs">
      <% cats.each_with_index do |cat, i| %>
      <button class="evt-tab aof-tab <%= i == 0 ? 'active' : '' %>"
              data-cat="<%= cat['value'] %>"
              role="tab"
              aria-selected="<%= i == 0 ? 'true' : 'false' %>">
        <%= cat['label'] %>
      </button>
      <% end %>
    </div>

    <div class="aof-grid-wrap">
      <div class="aof-grid" id="aof-grid">
        <% items.each do |f| %>
        <div class="aof-card" data-cat="<%= f['category'] || 'raja-mahal' %>">
          <img src="<%= f['image'] %>" alt="Orchha fresco" loading="lazy">
          <div class="aof-card-logos">
            <img src="/images/mpt_logo.png" class="aw-logo-mpt" alt="MPT">
            <img src="/images/incredible_india.png" class="aw-logo-ii" alt="Incredible India">
          </div>
        </div>
        <% end %>
      </div>
      <p class="aof-empty" id="aof-empty" style="display:none;">No frescoes found in this category yet.</p>
      <button type="button" class="aof-load-more" id="aof-load-more" style="display:none;">Load More</button>

    </div>
  </section>

  <%# ── VISIT ORCHHA (reused) ──────────────────────────── %>
  <div class="visit-wrap">
    <div class="visit-section">
      <div class="visit-bg-img" style="background-image: url('<%= vs['bgImage'] || '/images/visit_orchha_bg.jpg' %>')"></div>
      <div class="visit-content">
        <h2 class="visit-heading"><em>Visit</em> Orchha</h2>
        <div class="visit-links">
          <% (vs['links'] || [{'label'=>'How to Reach Orchha','url'=>'/reach'},{'label'=>'Travel Options','url'=>'/travel'},{'label'=>'Stay Options','url'=>'/stay'}]).each do |lnk| %>
          <a href="<%= lnk['url'] %>" class="visit-link"><%= lnk['label'] %></a>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── FOOTER ─────────────────────────────────────────── %>
  <footer class="footer">
    <div class="footer-container">
      <div class="footer-inner">
        <div class="footer-links">
          <% ft_links.each do |lnk| %>
          <a href="<%= lnk['url'] %>" class="footer-link"><%= lnk['label'] %></a>
          <% end %>
        </div>
        <div class="footer-logos">
          <img src="/images/incredible_india.png" alt="Incredible India" class="footer-logo-ii">
          <img src="/images/mpt_logo.png" alt="MPTDC" class="footer-logo-mptdc">
          <img src="/images/footer_logo_sabhyata.png" alt="Sabhyata Foundation" class="footer-logo-sabhyata">
        </div>
        <div class="footer-map-col">
          <div class="footer-map">
            <iframe src="https://www.google.com/maps?q=Orchha,+Madhya+Pradesh,+India&z=14&output=embed" loading="lazy" title="Orchha location map" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
          </div>
          <div class="footer-contact">
            <span class="footer-contact-label">Contact Us:</span>
            <div class="footer-contact-items">
              <a href="mailto:<%= ft['email'] || 'contact@orchha.com' %>" class="footer-contact-item">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 6.5A1.5 1.5 0 0 1 4.5 5h15A1.5 1.5 0 0 1 21 6.5v11a1.5 1.5 0 0 1-1.5 1.5h-15A1.5 1.5 0 0 1 3 17.5v-11Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="m4 6.5 8 6.5 8-6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <%= ft['email'] || 'contact@orchha.com' %>
              </a>
              <a href="tel:<%= (ft['phone'] || '+91 87963 83600').gsub(/[^\d+]/, '') %>" class="footer-contact-item">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5.4 3.6h3l1.6 4.4-2.1 1.6a12.4 12.4 0 0 0 5.5 5.5l1.6-2.1 4.4 1.6v3a1.5 1.5 0 0 1-1.6 1.5A16.9 16.9 0 0 1 3.9 5.2a1.5 1.5 0 0 1 1.5-1.6Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                <%= ft['phone'] || '+91 87963 83600' %>
              </a>
            </div>
          </div>
        </div>
      </div>
      <hr class="footer-divider">
      <div class="footer-bottom">
        <span class="footer-copy"><%= ft['copyright'] || '@2026ORCHHA' %></span>
        <span class="footer-copy"><%= ft['org'] || 'SABHYATA Foundation' %></span>
      </div>
    </div>
  </footer>

</div><%# /.aof-page %>

<script>
  // ── Navbar dropdown ───────────────────────────────────────
  const aofBtn = document.querySelector('.hist-nav-discover-btn');
  const aofDd  = document.querySelector('.hist-nav-dropdown');
  if (aofBtn && aofDd) {
    let aofCloseTimer;
    function openAofDd() {
      clearTimeout(aofCloseTimer);
      const r = aofBtn.getBoundingClientRect();
      aofDd.style.top  = (r.bottom + 8) + 'px';
      aofDd.style.left = r.left + 'px';
      aofDd.classList.add('open');
      aofBtn.classList.add('open');
      aofBtn.setAttribute('aria-expanded', 'true');
    }
    function closeAofDd() {
      aofDd.classList.remove('open');
      aofBtn.classList.remove('open');
      aofBtn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseAofDd() { aofCloseTimer = setTimeout(closeAofDd, 200); }
    aofBtn.addEventListener('mouseenter', openAofDd);
    aofBtn.addEventListener('mouseleave', scheduleCloseAofDd);
    aofDd.addEventListener('mouseenter', () => clearTimeout(aofCloseTimer));
    aofDd.addEventListener('mouseleave', scheduleCloseAofDd);
    aofBtn.addEventListener('click', e => { if (aofDd.classList.contains('open')) return; e.preventDefault(); openAofDd(); });
    document.addEventListener('click', closeAofDd);
    aofDd.addEventListener('click', e => e.stopPropagation());
  }

  // ── Mobile hamburger menu ───────────────────────────────────
  const histHamburgerBtn = document.getElementById('hist-nav-hamburger-btn');
  const histMobileMenu   = document.getElementById('hist-nav-mobile-menu');
  const histMobileClose  = document.getElementById('hist-nav-mobile-close-btn');
  if (histHamburgerBtn && histMobileMenu) {
    function openHistMobileMenu() {
      histMobileMenu.classList.add('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeHistMobileMenu() {
      histMobileMenu.classList.remove('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    histHamburgerBtn.addEventListener('click', openHistMobileMenu);
    if (histMobileClose) histMobileClose.addEventListener('click', closeHistMobileMenu);
    histMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeHistMobileMenu));
  }

  // ── Filter by category (paged: 10 at a time via Load More) ──
  const aofCards = Array.from(document.querySelectorAll('.aof-card'));
  const aofTabs  = Array.from(document.querySelectorAll('.aof-tab'));
  const aofEmpty = document.getElementById('aof-empty');
  const aofMore  = document.getElementById('aof-load-more');
  const AOF_PAGE = 10;
  let aofCat = 'all';
  let aofLimit = AOF_PAGE;

  function applyAofFilter() {
    const matching = aofCards.filter(card => aofCat === 'all' || card.dataset.cat === aofCat);
    aofCards.forEach(card => { card.style.display = 'none'; });
    matching.slice(0, aofLimit).forEach(card => { card.style.display = ''; });
    aofEmpty.style.display = matching.length === 0 ? 'block' : 'none';
    if (aofMore) aofMore.style.display = matching.length > aofLimit ? 'inline-flex' : 'none';
  }

  if (aofMore) aofMore.addEventListener('click', () => {
    aofLimit += AOF_PAGE;
    applyAofFilter();
  });

  function activateAofTab(tab) {
    aofTabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
    tab.classList.add('active');
    tab.setAttribute('aria-selected','true');
    aofCat = tab.dataset.cat;
    aofLimit = AOF_PAGE;   // filter change restarts at the first 10
    applyAofFilter();
  }
  applyAofFilter();

  aofTabs.forEach(tab => {
    tab.addEventListener('click', () => activateAofTab(tab));
  });

  // Pre-select a category when linked as /art-frescoes?filter=<value>
  // (e.g. the "View more" button on a monument's Paintings section).
  const aofRequested = new URLSearchParams(window.location.search).get('filter');
  if (aofRequested) {
    const match = aofTabs.find(t => t.dataset.cat === aofRequested);
    if (match) activateAofTab(match);
  }
</script>
