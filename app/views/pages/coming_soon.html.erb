<%# Coming Soon page — plain site background, title-style text centred.
    Used for Night Walk, individual museums, and individual freedom fighters. %>
<% nav = (@home['nav'] || {})
   dd  = nav['discoverDropdown'] || []
%>

<div class="cs-page">

  <%# ── NAVBAR (same pattern as listing pages) ─────────────── %>
  <div class="mon-nav-wrap">
    <nav class="hist-navbar">
      <div class="nav-links">
        <div class="nav-discover">
          <a href="/" class="hist-nav-link hist-nav-discover-btn" aria-expanded="false" aria-haspopup="true">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <a href="/plan-your-visit" class="hist-nav-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-link">News</a>
        <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-link">Sabhyata Foundation</a>
      </div>
      <button class="hist-nav-hamburger" id="hist-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-book-btn">Book Tickets</a>
    </nav>

    <div class="hist-nav-mobile-menu" id="hist-nav-mobile-menu">
      <button class="hist-nav-mobile-close" id="hist-nav-mobile-close-btn" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="/" class="nav-mobile-wordmark" aria-label="Home">ORCHHA</a>
      <div class="hist-nav-mobile-links">
        <div class="nav-mobile-group">
          <button type="button" class="hist-nav-mobile-link nav-mobile-group-btn" aria-expanded="false">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="nav-mobile-group-items">
            <% dd.each do |item| %>
            <a href="<%= item['url'] %>" class="hist-nav-mobile-link nav-mobile-sub-link"><%= item['label'] %></a>
            <% end %>
          </div>
        </div>
        <a href="/plan-your-visit" class="hist-nav-mobile-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-mobile-link">News</a>
        <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-mobile-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-mobile-link">Sabhyata Foundation</a>
      </div>
      <div class="nav-mobile-cta-row">
        <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-nav-mobile-book-btn">Book Tickets</a>
        <a href="/hoho" class="hist-nav-mobile-book-btn nav-mobile-hoho-btn">HOHO Service</a>
      </div>
    </div>

    <div class="hist-nav-dropdown" role="menu">
      <% dd.each do |item| %>
      <a href="<%= item['url'] %>" class="hist-nav-dropdown-item" role="menuitem"><%= item['label'] %></a>
      <% end %>
    </div>
  </div>

  <%# ── CENTRED TITLE ───────────────────────────────────────── %>
  <main class="cs-content">
    <% if @title.present? %>
    <p class="cs-eyebrow"><%= @title %></p>
    <% end %>
    <h1 class="cs-heading">Coming Soon..</h1>
  </main>

</div><%# /.cs-page %>

<script>
  // ── Navbar dropdown ───────────────────────────────────────
  (function() {
    const btn = document.querySelector('.hist-nav-discover-btn');
    const dd  = document.querySelector('.hist-nav-dropdown');
    if (btn && dd) {
      let timer;
      function openDd() {
        clearTimeout(timer);
        const r = btn.getBoundingClientRect();
        dd.style.top  = (r.bottom + 8) + 'px';
        dd.style.left = r.left + 'px';
        dd.classList.add('open');
        btn.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
      function closeDd() {
        dd.classList.remove('open');
        btn.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
      function scheduleClose() { timer = setTimeout(closeDd, 200); }
      btn.addEventListener('mouseenter', openDd);
      btn.addEventListener('mouseleave', scheduleClose);
      dd.addEventListener('mouseenter', () => clearTimeout(timer));
      dd.addEventListener('mouseleave', scheduleClose);
      btn.addEventListener('click', e => { if (dd.classList.contains('open')) return; e.preventDefault(); openDd(); });
      document.addEventListener('click', closeDd);
      dd.addEventListener('click', e => e.stopPropagation());
    }

    // ── Mobile hamburger menu ─────────────────────────────────
    const hamburger = document.getElementById('hist-nav-hamburger-btn');
    const menu      = document.getElementById('hist-nav-mobile-menu');
    const close     = document.getElementById('hist-nav-mobile-close-btn');
    if (hamburger && menu) {
      function openMenu()  { menu.classList.add('open');    hamburger.setAttribute('aria-expanded', 'true');  document.body.style.overflow = 'hidden'; }
      function closeMenu() { menu.classList.remove('open'); hamburger.setAttribute('aria-expanded', 'false'); document.body.style.overflow = ''; }
      hamburger.addEventListener('click', openMenu);
      if (close) close.addEventListener('click', closeMenu);
      menu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
    }
  })();
</script>
