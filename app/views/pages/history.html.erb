<%# History of Orchha page %>
<% hero  = @page['hero']       || {}
   tl    = @page['timeline']   || []
   no    = @page['newOrchha']  || {}
   nc    = @page['newChapter'] || {}
   qt    = @page['quote']      || {}
   mp    = @page['mptb']       || {}
   ft    = (@home['footer']    || {})
   ft_links = ft['links'] || []
   vs    = @home['visit']      || {}
%>

<%# Sticky HOHO button %>
<div class="sticky-hoho">
  <a href="/hoho">HOHO Service</a>
</div>

<%# ── PAGE WRAPPER ──────────────────────────────────── %>
<div class="hist-page">

  <%# ── HERO ──────────────────────────────────────────── %>
  <section class="hist-hero">
    <div class="hist-hero-inner">
      <%# Navbar %>
      <% nav = @home['nav'] || {}; dd = nav['discoverDropdown'] || [] %>
      <nav class="hist-navbar">
        <div class="nav-links">
          <div class="nav-discover">
            <a href="/" class="hist-nav-link hist-nav-discover-btn" aria-expanded="false" aria-haspopup="true">
              Discover Orchha
              <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
          <a href="/plan-your-visit" class="hist-nav-link">Plan Your Visit</a>
          <a href="/news" class="hist-nav-link">News</a>
          <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-link">Support Us</a>
          <a href="/sabhyata" class="hist-nav-link">Sabhyata Foundation</a>
        </div>
        <button class="hist-nav-hamburger" id="hist-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
          <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-book-btn">Book Tickets</a>
      </nav>

      <div class="hist-nav-mobile-menu" id="hist-nav-mobile-menu">
        <button class="hist-nav-mobile-close" id="hist-nav-mobile-close-btn" aria-label="Close menu">
          <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="hist-nav-mobile-links">
          <a href="/" class="hist-nav-mobile-link">Home</a>
          <% dd.each do |item| %>
          <a href="<%= item['url'] %>" class="hist-nav-mobile-link"><%= item['label'] %></a>
          <% end %>
          <a href="/plan-your-visit" class="hist-nav-mobile-link">Plan Your Visit</a>
          <a href="/news" class="hist-nav-mobile-link">News</a>
          <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-mobile-link">Support Us</a>
          <a href="/sabhyata" class="hist-nav-mobile-link">Sabhyata Foundation</a>
        </div>
        <div class="nav-mobile-cta-row">
          <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-nav-mobile-book-btn">Book Tickets</a>
          <a href="/hoho" class="hist-nav-mobile-book-btn nav-mobile-hoho-btn">HOHO Service</a>
        </div>
      </div>

      <%# Discover dropdown — kept outside .hist-navbar because its backdrop-filter
          creates a new containing block for position:fixed descendants %>
      <div class="hist-nav-dropdown" role="menu">
        <% dd.each do |item| %>
        <a href="<%= item['url'] %>" class="hist-nav-dropdown-item" role="menuitem"><%= item['label'] %></a>
        <% end %>
      </div>

      <%# Hero content: left text + right image %>
      <div class="hist-hero-content">
        <div class="hist-hero-text">
          <%# Figma 3168-10955..57: heading line 1, then subtitle, then line 2 %>
          <h1 class="hist-hero-heading"><%= hero['heading1'] || 'A Kingdom Built' %></h1>
          <p class="hist-hero-subtitle"><%= hero['subtitle'] || '' %></p>
          <p class="hist-hero-heading hist-hero-heading--below" aria-hidden="true"><%= hero['heading2'] || 'on the Betwa' %></p>
        </div>
        <div class="hist-hero-image">
          <img src="<%= hero['image'] || '/images/history_hero.jpg' %>" alt="Orchha Heritage">
        </div>
      </div>
    </div>
  </section>

  <%# ── PAGE TITLE ─────────────────────────────────────── %>
  <h2 class="hist-page-title"><%= @page['pageTitle'] || 'History of Orchha' %></h2>

  <%# ── TIMELINE (desktop) ─────────────────────────────── %>
  <section class="hist-timeline-section hist-timeline-desktop">
    <div class="hist-timeline-line"></div>
    <div class="hist-timeline-entries">
      <% tl.each_with_index do |entry, i| %>
      <div class="hist-tl-entry <%= i.even? ? 'hist-tl-ltr' : 'hist-tl-rtl' %>">
        <% if i.even? %>
          <%# text | year | image %>
          <div class="hist-tl-text">
            <h3 class="hist-tl-heading"><%= entry['heading'] %></h3>
            <p class="hist-tl-body"><%= entry['body'] %></p>
          </div>
          <div class="hist-tl-year-badge"><%= entry['year'] %></div>
          <div class="hist-tl-img">
            <img src="<%= entry['image'] %>" alt="<%= entry['heading'] %>">
          </div>
        <% else %>
          <%# image | year | text %>
          <div class="hist-tl-img">
            <img src="<%= entry['image'] %>" alt="<%= entry['heading'] %>">
          </div>
          <div class="hist-tl-year-badge"><%= entry['year'] %></div>
          <div class="hist-tl-text">
            <h3 class="hist-tl-heading"><%= entry['heading'] %></h3>
            <p class="hist-tl-body"><%= entry['body'] %></p>
          </div>
        <% end %>
      </div>
      <% end %>
    </div>
  </section>

  <%# ── TIMELINE (mobile — sticky scroll-jack) ──────────── %>
  <% if tl.present? %>
  <section class="history-mobile" data-history-timeline aria-label="History of Orchha">
    <div class="history-mobile__sticky">
      <div class="history-mobile__visuals" aria-hidden="true">
        <% tl.each_with_index do |entry, i| %>
        <figure class="history-mobile__visual <%= 'is-active' if i.zero? %>" data-history-visual>
          <img src="<%= entry['image'] %>" alt="<%= entry['heading'] %>" loading="<%= i.zero? ? 'eager' : 'lazy' %>">
        </figure>
        <% end %>
      </div>

      <div class="history-mobile__content">
        <% tl.each_with_index do |entry, i| %>
        <article class="history-mobile__story <%= 'is-active' if i.zero? %>" data-history-story aria-hidden="<%= i.zero? ? 'false' : 'true' %>">
          <p class="history-mobile__year"><%= entry['year'] %></p>
          <h3><%= entry['heading'] %></h3>
          <p><%= entry['body'] %></p>
        </article>
        <% end %>
      </div>

      <div class="history-mobile__progress" aria-hidden="true"><span></span></div>
    </div>
  </section>
  <% end %>

  <%# ── THE NEW ORCHHA ─────────────────────────────────── %>
  <section class="hist-new-orchha">
    <div class="hist-new-orchha-img" style="background-image: url('<%= no['image'] || '/images/history_new_orchha_v2.jpg' %>')">
      <div class="hist-new-orchha-overlay">
        <h2 class="hist-new-orchha-heading"><%= no['heading'] || 'Experience The New Orchha Living Heritage' %></h2>
      </div>
    </div>
    <%# New Chapter text below %>
    <div class="hist-new-chapter">
      <h2 class="hist-nc-heading"><%= nc['heading'] || 'A New Chapter for an Ancient Kingdom' %></h2>
      <div class="hist-nc-body">
        <% (nc['paragraphs'] || []).each do |para| %>
        <p><%= raw(paragraph_html(para)) %></p>
        <% end %>
      </div>
    </div>
  </section>

  <%# ── QUOTE ──────────────────────────────────────────── %>
  <section class="hist-quote-section">
    <div class="hist-quote-markrow" aria-hidden="true">
      <img src="/images/quote_mark.svg" alt="" class="hist-quote-mark">
    </div>
    <p class="hist-quote-text"><%= qt['text'] || '' %></p>
    <a href="<%= qt['buttonUrl'] || '/sabhyata' %>" class="hist-quote-btn"><%= qt['buttonLabel'] || 'About Sabhyata' %></a>
  </section>

  <%# ── MPTB ───────────────────────────────────────────── %>
  <section class="hist-mptb-section">
    <div class="hist-mptb-inner">
      <div class="hist-mptb-header">
        <span class="hist-mptb-acronym"><%= mp['acronym'] || 'MPTB' %></span>
        <div class="hist-mptb-divider"></div>
        <span class="hist-mptb-fullname"><%= mp['fullName'] || 'Madhya Pradesh Tourism Board' %></span>
      </div>
      <div class="hist-mptb-body">
        <div class="hist-mptb-text">
          <% (mp['paragraphs'] || []).each do |para| %>
          <p><%= paragraph_html(para) %></p>
          <% end %>
        </div>
        <div class="hist-mptb-images">
          <div class="hist-mptb-img1">
            <img src="<%= mp['image1'] || '/images/history_mptb_1.jpg' %>" alt="MPTB">
          </div>
          <div class="hist-mptb-img2">
            <img src="<%= mp['image2'] || '/images/history_mptb_2.jpg' %>" alt="MPTB">
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ── VISIT ORCHHA (reused) ──────────────────────────── %>
  <div class="visit-wrap">
    <div class="visit-section">
      <div class="visit-bg-img" style="background-image: url('<%= vs['bgImage'] || '/images/visit_orchha_bg.jpg' %>')"></div>
      <div class="visit-content">
        <h2 class="visit-heading"><em>Visit</em> Orchha</h2>
        <div class="visit-links">
          <% (vs['links'] || [{'label'=>'How to Reach Orchha','url'=>'/reach'},{'label'=>'Travel Options','url'=>'/travel'},{'label'=>'Stay Options','url'=>'/stay'}]).each do |lnk| %>
          <a href="<%= lnk['url'] %>" class="visit-link"><%= lnk['label'] %></a>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── FOOTER (reused) ────────────────────────────────── %>
<%= render 'shared/footer', ft: ft %>

</div><%# /.hist-page %>

<script>
  // History page nav dropdown
  const histBtn = document.querySelector('.hist-nav-discover-btn');
  const histDd  = document.querySelector('.hist-nav-dropdown');
  if (histBtn && histDd) {
    let histCloseTimer;
    function openHistDd() {
      clearTimeout(histCloseTimer);
      const r = histBtn.getBoundingClientRect();
      histDd.style.top  = (r.bottom + 8) + 'px';
      histDd.style.left = r.left + 'px';
      histDd.classList.add('open');
      histBtn.classList.add('open');
      histBtn.setAttribute('aria-expanded', 'true');
    }
    function closeHistDd() {
      histDd.classList.remove('open');
      histBtn.classList.remove('open');
      histBtn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseHistDd() { histCloseTimer = setTimeout(closeHistDd, 200); }
    histBtn.addEventListener('mouseenter', openHistDd);
    histBtn.addEventListener('mouseleave', scheduleCloseHistDd);
    histDd.addEventListener('mouseenter', () => clearTimeout(histCloseTimer));
    histDd.addEventListener('mouseleave', scheduleCloseHistDd);
    histBtn.addEventListener('click', function(e) {
      if (histDd.classList.contains('open')) return;
      e.preventDefault();
      openHistDd();
    });
    document.addEventListener('click', closeHistDd);
    histDd.addEventListener('click', function(e) { e.stopPropagation(); });
  }

  // Mobile hamburger menu
  const histHamburgerBtn = document.getElementById('hist-nav-hamburger-btn');
  const histMobileMenu   = document.getElementById('hist-nav-mobile-menu');
  const histMobileClose  = document.getElementById('hist-nav-mobile-close-btn');
  if (histHamburgerBtn && histMobileMenu) {
    function openHistMobileMenu() {
      histMobileMenu.classList.add('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeHistMobileMenu() {
      histMobileMenu.classList.remove('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    histHamburgerBtn.addEventListener('click', openHistMobileMenu);
    if (histMobileClose) histMobileClose.addEventListener('click', closeHistMobileMenu);
    histMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeHistMobileMenu));
  }

  // ── Mobile history timeline — arc carousel scroll-jack ────────
  (function () {
    const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));

    function mountHistoryTimeline(timeline) {
      const stories = Array.from(timeline.querySelectorAll('[data-history-story]'));
      const visuals = Array.from(timeline.querySelectorAll('[data-history-visual]'));
      const count = Math.min(stories.length, visuals.length);
      if (!count) return;

      timeline.style.setProperty('--history-count', count);
      let nearest = -1;
      let ticking = false;

      function layout() {
        ticking = false;
        const rect = timeline.getBoundingClientRect();
        const scrollable = timeline.offsetHeight - window.innerHeight;
        const progress = scrollable > 0 ? clamp(-rect.top / scrollable, 0, 1) : 0;
        const activeFloat = progress * (count - 1);
        timeline.style.setProperty('--history-progress', progress.toFixed(4));

        // Vertical gap between cards and how far off-axis cards drift left.
        const spacing = clamp(window.innerHeight * 0.16, 96, 150);
        const pushX   = clamp(window.innerWidth * 0.17, 54, 110);

        visuals.forEach((v, i) => {
          const off = i - activeFloat;         // continuous distance from the sharp front card
          const a = Math.abs(off);
          const ty = off * spacing;            // stack vertically
          const tx = -Math.pow(a, 1.3) * pushX; // curve away to the left with distance
          const rot = clamp(off * 22, -75, 75); // rotate more the further out
          const scale = a < 0.5 ? (1.06 - a * 0.14) : Math.max(0.62, 0.9 - (a - 0.5) * 0.12);
          const blur = a < 0.35 ? 0 : Math.min(1.6, (a - 0.35) * 1.7);
          const opacity = a > 3.4 ? 0 : (a > 2.4 ? clamp(1 - (a - 2.4), 0, 1) : 1);
          v.style.transform = `translate(-50%, -50%) translate(${tx.toFixed(1)}px, ${ty.toFixed(1)}px) rotate(${rot.toFixed(2)}deg) scale(${scale.toFixed(3)})`;
          v.style.filter = blur ? `blur(${blur.toFixed(2)}px)` : 'none';
          v.style.opacity = opacity.toFixed(3);
          v.style.zIndex = String(100 - Math.round(a * 10));
        });

        const idx = clamp(Math.round(activeFloat), 0, count - 1);
        if (idx !== nearest) {
          nearest = idx;
          stories.forEach((s, i) => {
            const on = i === idx;
            s.classList.toggle('is-active', on);
            s.setAttribute('aria-hidden', String(!on));
          });
          visuals.forEach((v, i) => v.classList.toggle('is-active', i === idx));
        }
      }

      function requestLayout() {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(layout);
      }

      layout();
      window.addEventListener('scroll', requestLayout, { passive: true });
      window.addEventListener('resize', requestLayout, { passive: true });
    }

    document.querySelectorAll('[data-history-timeline]').forEach(mountHistoryTimeline);
  })();
</script>
