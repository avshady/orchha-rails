<%# Shared fixed action-tabs bar with a real audio guide player.
    locals: tracks (Array of {language, audio}), label (String fallback),
            extra_tabs (Array of tab labels, default Virtual Tour + Translate). %>
<% tracks = (local_assigns[:tracks] || []).select { |t| t['audio'].to_s.strip.present? }
   label  = local_assigns[:label] || 'Audio Guide'
   extra_tabs = local_assigns.fetch(:extra_tabs, ['Virtual Tour', 'Translate'])
   has_audio = tracks.any?
%>
<div class="mdet-action-tabs" id="mdet-action-tabs">
  <div class="mdet-audio-wrap">
    <div class="mdet-audio-panel<%= ' mdet-audio-panel--live' if has_audio %>" id="mdet-audio-panel"
         <%= "data-tracks=#{tracks.to_json.encode(xml: :attr)}".html_safe if has_audio %>>
      <button class="mdet-audio-play" id="mdet-audio-play-btn" aria-label="Play"<%= ' disabled' unless has_audio %>>
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" id="mdet-audio-icon" data-state="paused">
          <circle cx="16" cy="16" r="16" fill="white"/>
          <polygon points="13,10 13,22 23,16" fill="#6e1603"/>
        </svg>
      </button>
      <% if has_audio && tracks.size > 1 %>
        <select class="mdet-audio-lang" id="mdet-audio-lang" aria-label="Audio language">
          <% tracks.each_with_index do |t, i| %>
            <option value="<%= i %>"><%= t['language'].presence || "Track #{i + 1}" %></option>
          <% end %>
        </select>
      <% else %>
        <span class="mdet-audio-track"><%= has_audio ? (tracks.first['language'].presence || label) : label %></span>
      <% end %>
      <div class="mdet-audio-wave">
        <svg viewBox="0 0 434 28" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <rect y="8" width="434" height="7" rx="3.5" fill="white" fill-opacity="0.4"/>
          <rect x="2" y="10" width="47" height="3" rx="1.5" fill="white"/>
          <circle cx="55.5" cy="11.5" r="9.5" fill="white"/>
          <circle cx="55.5" cy="11.5" r="8.5" stroke="rgba(102,18,0,0.6)" stroke-width="2"/>
        </svg>
        <% if has_audio %><span class="mdet-audio-progress" id="mdet-audio-progress"></span><% end %>
      </div>
      <span class="mdet-audio-time" id="mdet-audio-time"><%= has_audio ? '0:00 / 0:00' : '0:00 / 3:00' %></span>
      <% if has_audio %><audio id="mdet-audio-el" preload="metadata" src="<%= tracks.first['audio'] %>"></audio><% end %>
    </div>
    <button class="mdet-action-tab" id="mdet-audio-btn">Audio Guide</button>
  </div>
  <% extra_tabs.each do |t| %>
    <button class="mdet-action-tab"><%= t %></button>
  <% end %>
</div>

<% if has_audio %>
<script>
(function() {
  const panel = document.getElementById('mdet-audio-panel');
  const audio = document.getElementById('mdet-audio-el');
  const playBtn = document.getElementById('mdet-audio-play-btn');
  const icon = document.getElementById('mdet-audio-icon');
  const timeEl = document.getElementById('mdet-audio-time');
  const progress = document.getElementById('mdet-audio-progress');
  const langSel = document.getElementById('mdet-audio-lang');
  if (!audio || !playBtn) return;

  let tracks = [];
  try { tracks = JSON.parse(panel.dataset.tracks || '[]'); } catch (e) {}

  const PLAY = '<polygon points="13,10 13,22 23,16" fill="#6e1603"/>';
  const PAUSE = '<rect x="12" y="10" width="3.4" height="12" rx="1" fill="#6e1603"/><rect x="17.6" y="10" width="3.4" height="12" rx="1" fill="#6e1603"/>';
  function setIcon(playing) {
    icon.innerHTML = '<circle cx="16" cy="16" r="16" fill="white"/>' + (playing ? PAUSE : PLAY);
    icon.dataset.state = playing ? 'playing' : 'paused';
  }
  function fmt(s) {
    if (!isFinite(s)) return '0:00';
    const m = Math.floor(s / 60), sec = Math.floor(s % 60);
    return m + ':' + String(sec).padStart(2, '0');
  }
  function updateTime() {
    timeEl.textContent = fmt(audio.currentTime) + ' / ' + fmt(audio.duration);
    if (progress && audio.duration) progress.style.width = (audio.currentTime / audio.duration * 100) + '%';
  }

  playBtn.addEventListener('click', () => { audio.paused ? audio.play() : audio.pause(); });
  audio.addEventListener('play', () => setIcon(true));
  audio.addEventListener('pause', () => setIcon(false));
  audio.addEventListener('ended', () => { setIcon(false); if (progress) progress.style.width = '0%'; });
  audio.addEventListener('timeupdate', updateTime);
  audio.addEventListener('loadedmetadata', updateTime);

  if (langSel) {
    langSel.addEventListener('change', () => {
      const t = tracks[+langSel.value];
      if (!t) return;
      const wasPlaying = !audio.paused;
      audio.src = t.audio;
      audio.load();
      if (wasPlaying) audio.play();
    });
  }
})();
</script>
<% end %>
