<%# Orchha in News — filterable, searchable news grid %>
<% ft       = (@home['footer'] || {})
   ft_links = ft['links'] || []
   nav      = @home['nav']   || {}
   dd       = nav['discoverDropdown'] || []
   vs       = @home['visit'] || {}
   items    = @items.presence || []
   cats     = @page['filterCategories'] || [
     {'label'=>'All','value'=>'all'},
     {'label'=>'Heritage','value'=>'heritage'},
     {'label'=>'Tourism','value'=>'tourism'},
     {'label'=>'Events','value'=>'events'}
   ]
%>

<%# Sticky HOHO button %>
<div class="sticky-hoho">
  <a href="/hoho">HOHO Service</a>
</div>

<div class="news-p-page">

  <%# ── NAVBAR ─────────────────────────────────────────── %>
  <div class="mon-nav-wrap">
    <nav class="hist-navbar">
      <div class="nav-links">
        <div class="nav-discover">
          <a href="/" class="hist-nav-link hist-nav-discover-btn" aria-expanded="false" aria-haspopup="true">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <a href="/plan-your-visit" class="hist-nav-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-link">News</a>
        <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-link">Sabhyata Foundation</a>
      </div>
      <button class="hist-nav-hamburger" id="hist-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-book-btn">Book Tickets</a>
    </nav>

    <div class="hist-nav-mobile-menu" id="hist-nav-mobile-menu">
      <button class="hist-nav-mobile-close" id="hist-nav-mobile-close-btn" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="/" class="nav-mobile-wordmark" aria-label="Home">ORCHHA</a>
      <div class="hist-nav-mobile-links">
        <div class="nav-mobile-group">
          <button type="button" class="hist-nav-mobile-link nav-mobile-group-btn" aria-expanded="false">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="nav-mobile-group-items">
            <% dd.each do |item| %>
            <a href="<%= item['url'] %>" class="hist-nav-mobile-link nav-mobile-sub-link"><%= item['label'] %></a>
            <% end %>
          </div>
        </div>
        <a href="/plan-your-visit" class="hist-nav-mobile-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-mobile-link">News</a>
        <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="hist-nav-mobile-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-mobile-link">Sabhyata Foundation</a>
      </div>
      <div class="nav-mobile-cta-row">
        <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-nav-mobile-book-btn">Book Tickets</a>
        <a href="/hoho" class="hist-nav-mobile-book-btn nav-mobile-hoho-btn">HOHO Service</a>
      </div>
    </div>

    <%# Discover dropdown — kept outside .hist-navbar because its backdrop-filter
        creates a new containing block for position:fixed descendants %>
    <div class="hist-nav-dropdown" role="menu">
      <% dd.each do |item| %>
      <a href="<%= item['url'] %>" class="hist-nav-dropdown-item" role="menuitem"><%= item['label'] %></a>
      <% end %>
    </div>
  </div>

  <%# ── HEADER ─────────────────────────────────────────── %>
  <header class="news-p-header">
    <h1 class="news-p-heading"><%= @page['heading'] || 'Orchha in News' %></h1>
    <p class="news-p-subheading"><%= @page['subheading'] || 'A curated stream of heritage stories, conservation updates, cultural events, and evolving narratives from the heart of Orchha.' %></p>
  </header>

  <%# ── NEWS SECTION ──────────────────────────────────── %>
  <section class="news-p-section">

    <div class="news-p-filter-row">
      <div class="evt-filter-tabs">
        <% cats.each_with_index do |cat, i| %>
        <button class="evt-tab news-p-tab <%= i == 0 ? 'active' : '' %>"
                data-cat="<%= cat['value'] %>"
                role="tab"
                aria-selected="<%= i == 0 ? 'true' : 'false' %>">
          <%= cat['label'] %>
        </button>
        <% end %>
      </div>
      <div class="news-p-search">
        <input type="text" id="news-p-search-input" placeholder="Search news..." aria-label="Search news">
        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="9" cy="9" r="7" stroke="#6e1603" stroke-width="1.6"/><path d="M14.5 14.5 18 18" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/></svg>
      </div>
    </div>

    <div class="news-p-grid" id="news-p-grid">
      <% items.each do |n| %>
      <a href="<%= n['link'].presence || '#' %>" class="news-p-card" data-cat="<%= n['category'] || 'heritage' %>" data-search="<%= "#{n['heading']} #{n['text']}".downcase %>"
         data-pop-title="<%= n['heading'] %>" data-pop-tag="<%= (n['category'] || 'heritage').capitalize %>" data-pop-date="<%= n['date'] %>"
         data-pop-img="<%= n['image'] %>" data-pop-text="<%= n['text'] %>" data-pop-link="<%= n['link'] %>">
        <div class="news-p-photo">
          <img src="<%= n['image'] %>" alt="<%= n['heading'] %>" loading="lazy">
          <div class="news-p-logos">
            <img src="/images/mpt_logo.png" class="aw-logo-mpt" alt="MPT">
            <img src="/images/incredible_india.png" class="aw-logo-ii" alt="Incredible India">
          </div>
        </div>
        <div class="news-p-body">
          <div class="news-p-meta">
            <span class="news-p-cat"><%= (n['category'] || 'heritage').capitalize %></span>
            <span class="news-p-dot">&bull;</span>
            <span class="news-p-date"><%= n['date'] %></span>
          </div>
          <h3 class="news-p-title"><%= n['heading'] %></h3>
          <p class="news-p-text"><%= n['text'] %></p>
        </div>
        <span class="news-p-readmore">
          Read more
          <svg viewBox="0 0 5 9" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1l3 3.5L1 8" stroke="#6e1603" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
      <% end %>
    </div>
    <p class="news-p-empty" id="news-p-empty" style="display:none;">No news items match your filter.</p>
  </section>

  <%# ── VISIT ORCHHA (reused) ──────────────────────────── %>
  <div class="visit-wrap">
    <div class="visit-section">
      <div class="visit-bg-img" style="background-image: url('<%= vs['bgImage'] || '/images/visit_orchha_bg.jpg' %>')"></div>
      <div class="visit-content">
        <h2 class="visit-heading"><em>Visit</em> Orchha</h2>
        <div class="visit-links">
          <% (vs['links'] || [{'label'=>'How to Reach Orchha','url'=>'/reach'},{'label'=>'Travel Options','url'=>'/travel'},{'label'=>'Stay Options','url'=>'/stay'}]).each do |lnk| %>
          <a href="<%= lnk['url'] %>" class="visit-link"><%= lnk['label'] %></a>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── FOOTER ─────────────────────────────────────────── %>
<%= render 'shared/footer', ft: ft %>

</div><%# /.news-p-page %>

<%= render 'shared/news_popup' %>

<script>
  // ── Navbar dropdown ───────────────────────────────────────
  const newsPBtn = document.querySelector('.hist-nav-discover-btn');
  const newsPDd  = document.querySelector('.hist-nav-dropdown');
  if (newsPBtn && newsPDd) {
    let newsPCloseTimer;
    function openNewsPDd() {
      clearTimeout(newsPCloseTimer);
      const r = newsPBtn.getBoundingClientRect();
      newsPDd.style.top  = (r.bottom + 8) + 'px';
      newsPDd.style.left = r.left + 'px';
      newsPDd.classList.add('open');
      newsPBtn.classList.add('open');
      newsPBtn.setAttribute('aria-expanded', 'true');
    }
    function closeNewsPDd() {
      newsPDd.classList.remove('open');
      newsPBtn.classList.remove('open');
      newsPBtn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseNewsPDd() { newsPCloseTimer = setTimeout(closeNewsPDd, 200); }
    newsPBtn.addEventListener('mouseenter', openNewsPDd);
    newsPBtn.addEventListener('mouseleave', scheduleCloseNewsPDd);
    newsPDd.addEventListener('mouseenter', () => clearTimeout(newsPCloseTimer));
    newsPDd.addEventListener('mouseleave', scheduleCloseNewsPDd);
    newsPBtn.addEventListener('click', e => { if (newsPDd.classList.contains('open')) return; e.preventDefault(); openNewsPDd(); });
    document.addEventListener('click', closeNewsPDd);
    newsPDd.addEventListener('click', e => e.stopPropagation());
  }

  // ── Mobile hamburger menu ───────────────────────────────────
  const histHamburgerBtn = document.getElementById('hist-nav-hamburger-btn');
  const histMobileMenu   = document.getElementById('hist-nav-mobile-menu');
  const histMobileClose  = document.getElementById('hist-nav-mobile-close-btn');
  if (histHamburgerBtn && histMobileMenu) {
    function openHistMobileMenu() {
      histMobileMenu.classList.add('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeHistMobileMenu() {
      histMobileMenu.classList.remove('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    histHamburgerBtn.addEventListener('click', openHistMobileMenu);
    if (histMobileClose) histMobileClose.addEventListener('click', closeHistMobileMenu);
    histMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeHistMobileMenu));
  }

  // ── Filter by category + search ───────────────────────────────
  const newsPCards = Array.from(document.querySelectorAll('.news-p-card'));
  const newsPTabs  = Array.from(document.querySelectorAll('.news-p-tab'));
  const newsPEmpty = document.getElementById('news-p-empty');
  const newsPSearchInput = document.getElementById('news-p-search-input');
  let newsPActiveCat = 'all';
  let newsPQuery = '';

  function applyNewsPFilter() {
    let visible = 0;
    newsPCards.forEach(card => {
      const catOk = newsPActiveCat === 'all' || card.dataset.cat === newsPActiveCat;
      const searchOk = !newsPQuery || card.dataset.search.includes(newsPQuery);
      const show = catOk && searchOk;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    newsPEmpty.style.display = visible === 0 ? 'block' : 'none';
  }

  newsPTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      newsPTabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected','true');
      newsPActiveCat = tab.dataset.cat;
      applyNewsPFilter();
    });
  });

  if (newsPSearchInput) {
    newsPSearchInput.addEventListener('input', e => {
      newsPQuery = e.target.value.trim().toLowerCase();
      applyNewsPFilter();
    });
  }
</script>
