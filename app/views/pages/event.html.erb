<%# Event detail page — Figma 3272-13548: centred title + description,
    hero card, visitors/date stats, Archived Gallery carousel, Visit Orchha. %>
<% nav = (@home['nav'] || {})
   dd  = nav['discoverDropdown'] || []
   ft  = @home['footer'] || {}
   vs  = @home['visit']  || {}
   gallery = (@event['galleryImages'] || []).reject { |g| g.to_s.empty? }
%>

<div class="sticky-hoho"><a href="/hoho">HOHO Service</a></div>

<div class="mdet-nav-wrap">
  <nav class="mdet-navbar">
    <div class="mdet-nav-links">
      <div class="mdet-nav-discover">
        <a href="/" class="mdet-nav-link mdet-discover-btn" aria-expanded="false" aria-haspopup="true">
          Discover Orchha
          <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <a href="/plan-your-visit" class="mdet-nav-link">Plan Your Visit</a>
      <a href="/news"            class="mdet-nav-link">News</a>
      <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener"      class="mdet-nav-link">Support Us</a>
      <a href="/sabhyata"        class="mdet-nav-link">Sabhyata Foundation</a>
    </div>
    <button class="mdet-nav-hamburger" id="mdet-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="mdet-book-btn">Book Tickets</a>
  </nav>

  <div class="mdet-nav-mobile-menu" id="mdet-nav-mobile-menu">
    <button class="mdet-nav-mobile-close" id="mdet-nav-mobile-close-btn" aria-label="Close menu">
      <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <a href="/" class="nav-mobile-wordmark" aria-label="Home">ORCHHA</a>
    <div class="mdet-nav-mobile-links">
      <div class="nav-mobile-group">
        <button type="button" class="mdet-nav-mobile-link nav-mobile-group-btn" aria-expanded="false">
          Discover Orchha
          <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="nav-mobile-group-items">
          <% dd.each do |item| %>
          <a href="<%= item['url'] %>" class="mdet-nav-mobile-link nav-mobile-sub-link"><%= item['label'] %></a>
          <% end %>
        </div>
      </div>
      <a href="/plan-your-visit" class="mdet-nav-mobile-link">Plan Your Visit</a>
      <a href="/news" class="mdet-nav-mobile-link">News</a>
      <a href="https://pages.razorpay.com/pl_PWE9fVFc9oLCel/view" target="_blank" rel="noopener" class="mdet-nav-mobile-link">Support Us</a>
      <a href="/sabhyata" class="mdet-nav-mobile-link">Sabhyata Foundation</a>
    </div>
    <div class="nav-mobile-cta-row">
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="mdet-nav-mobile-book-btn">Book Tickets</a>
      <a href="/hoho" class="mdet-nav-mobile-book-btn nav-mobile-hoho-btn">HOHO Service</a>
    </div>
  </div>

  <div class="mdet-nav-dropdown" role="menu">
    <% dd.each do |item| %>
    <a href="<%= item['url'] %>" class="mdet-nav-dd-item" role="menuitem"><%= item['label'] %></a>
    <% end %>
  </div>
</div>

<div class="evd-page">

  <%# ── Title + description (centred) ─────────────────────── %>
  <header class="evd-header">
    <h1 class="evd-title"><%= @event['name'] %></h1>
    <% if @event['description'].present? %>
    <p class="evd-sub"><%= @event['description'] %></p>
    <% end %>
  </header>

  <%# ── Hero card ──────────────────────────────────────────── %>
  <div class="evd-hero">
    <%= hero_media_tag(@event['heroImage'].presence || @event['image'], alt: @event['name']) %>
    <div class="evd-hero-logos">
      <img src="/images/mpt_logo.png" class="aw-logo-mpt" alt="MPT">
      <img src="/images/incredible_india.png" class="aw-logo-ii" alt="Incredible India">
    </div>
  </div>

  <%# ── Stats row: visitors + date ─────────────────────────── %>
  <div class="evd-stats">
    <% if @event['estimatedVisitors'].present? %>
    <div class="evd-stat">
      <span class="evd-stat-icon">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="8.5" r="3.5" stroke="#6e1603" stroke-width="1.6"/><path d="M5.5 19c.8-3.2 3.4-5 6.5-5s5.7 1.8 6.5 5" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/></svg>
      </span>
      <div class="evd-stat-text">
        <span class="evd-stat-lbl">Estimated Visitors:</span>
        <span class="evd-stat-val"><%= @event['estimatedVisitors'] %></span>
      </div>
    </div>
    <% end %>
    <% if @event['date'].present? %>
    <div class="evd-stat">
      <span class="evd-stat-icon">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="6" width="16" height="14" rx="2" stroke="#6e1603" stroke-width="1.6"/><path d="M4 10h16M8 3.5V7M16 3.5V7" stroke="#6e1603" stroke-width="1.6" stroke-linecap="round"/></svg>
      </span>
      <div class="evd-stat-text">
        <span class="evd-stat-lbl">Date:</span>
        <span class="evd-stat-val"><%= @event['date'] %></span>
      </div>
    </div>
    <% end %>
  </div>

  <%# ── Archived Gallery carousel ──────────────────────────── %>
  <% if gallery.any? %>
  <section class="evd-gallery-band">
    <h2 class="evd-gallery-heading">Archived Gallery</h2>
    <div class="evd-carousel">
      <button type="button" class="evd-car-arrow evd-car-prev" aria-label="Previous photos">
        <svg viewBox="0 0 24 24" fill="none"><path d="M14.5 6l-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div class="evd-car-track" id="evd-car-track">
        <% gallery.each do |photo| %>
        <div class="evd-car-card">
          <img src="<%= photo %>" alt="<%= @event['name'] %> — archive photo" loading="lazy">
          <div class="evd-hero-logos">
            <img src="/images/mpt_logo.png" class="aw-logo-mpt" alt="MPT">
            <img src="/images/incredible_india.png" class="aw-logo-ii" alt="Incredible India">
          </div>
        </div>
        <% end %>
      </div>
      <button type="button" class="evd-car-arrow evd-car-next" aria-label="Next photos">
        <svg viewBox="0 0 24 24" fill="none"><path d="M9.5 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </section>
  <% end %>

  <%# ── Visit Orchha (shared component) ────────────────────── %>
  <div class="visit-wrap">
    <div class="visit-section">
      <div class="visit-bg-img" style="background-image: url('<%= vs['bgImage'] || '/images/visit_orchha_bg.jpg' %>')"></div>
      <div class="visit-content">
        <h2 class="visit-heading"><em>Visit</em> Orchha</h2>
        <div class="visit-links">
          <% (vs['links'] || [{'label'=>'How to Reach Orchha','url'=>'/reach'},{'label'=>'Travel Options','url'=>'/travel'},{'label'=>'Stay Options','url'=>'/stay'}]).each do |lnk| %>
          <a href="<%= lnk['url'] %>" class="visit-link"><%= lnk['label'] %></a>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Footer ─────────────────────────────────────────────── %>
<%= render 'shared/footer', ft: ft %>

</div><%# /.evd-page %>

<style>
  .evd-page { background: #e7ded5; min-height: 100vh; }
  .evd-header { max-width: 720px; margin: 0 auto; padding: 140px 24px 34px; text-align: center; }
  .evd-title {
    font-family: 'Scotch Display', serif; font-weight: 600; font-size: 62px;
    line-height: 1.05; color: #6e1603; margin: 0 0 14px; text-transform: capitalize;
  }
  .evd-sub {
    font-family: 'Gambetta Variable', serif; font-weight: 500; font-size: 18px;
    line-height: 1.45; color: #1a0e06; margin: 0;
  }
  .evd-hero { position: relative; max-width: 1200px; margin: 0 auto; border-radius: 14px; overflow: hidden; aspect-ratio: 2 / 1; }
  .evd-hero > img, .evd-hero > video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .evd-hero-logos { position: absolute; top: 14px; left: 0; right: 0; display: flex; justify-content: space-between; padding: 0 18px; }
  .evd-stats { display: flex; justify-content: center; gap: 90px; padding: 34px 24px 60px; flex-wrap: wrap; }
  .evd-stat { display: flex; align-items: center; gap: 14px; }
  .evd-stat-icon {
    width: 46px; height: 46px; border: 1.5px solid #6e1603; border-radius: 50%;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .evd-stat-icon svg { width: 24px; height: 24px; }
  .evd-stat-text { display: flex; flex-direction: column; }
  .evd-stat-lbl { font-family: 'Gambetta Variable', serif; font-size: 15px; color: #6e1603; }
  .evd-stat-val { font-family: 'Gambetta Variable', serif; font-weight: 700; font-size: 24px; color: #2a1000; }
  .evd-gallery-band { background: #ded3c4; padding: 56px 0 64px; }
  .evd-gallery-heading {
    font-family: 'Scotch Display', serif; font-weight: 600; font-size: 44px;
    color: #8d140c; text-align: center; margin: 0 0 36px;
  }
  .evd-carousel { position: relative; max-width: 1200px; margin: 0 auto; padding: 0 70px; }
  .evd-car-track {
    display: flex; gap: 24px; overflow-x: auto; scroll-behavior: smooth;
    scrollbar-width: none; scroll-snap-type: x mandatory;
  }
  .evd-car-track::-webkit-scrollbar { display: none; }
  .evd-car-card {
    position: relative; flex: 0 0 calc(50% - 12px);
    aspect-ratio: 34 / 25; border-radius: 10px; overflow: hidden; scroll-snap-align: start;
  }
  .evd-car-card > img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .evd-car-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 42px; height: 42px; border-radius: 50%;
    border: 1.5px solid #8d140c; background: transparent; color: #8d140c;
    display: flex; align-items: center; justify-content: center; cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .evd-car-arrow:hover { background: #8d140c; color: #ded3c4; }
  .evd-car-arrow svg { width: 22px; height: 22px; }
  .evd-car-prev { left: 12px; }
  .evd-car-next { right: 12px; }
  @media (max-width: 900px) {
    .evd-header { padding: 110px 20px 24px; }
    .evd-title { font-size: 40px; }
    .evd-sub { font-size: 16px; }
    .evd-hero { margin: 0 20px; aspect-ratio: 4 / 3; }
    .evd-stats { gap: 28px; flex-direction: column; align-items: center; padding: 28px 20px 44px; }
    .evd-gallery-heading { font-size: 32px; }
    .evd-carousel { padding: 0 54px; }
    .evd-car-card { flex: 0 0 100%; }
    .evd-car-prev { left: 6px; }
    .evd-car-next { right: 6px; }
  }
</style>

<script>
(function() {
  const navBtn = document.querySelector('.mdet-discover-btn');
  const navDd  = document.querySelector('.mdet-nav-dropdown');
  if (navBtn && navDd) {
    let navDdCloseTimer;
    function openDd() {
      clearTimeout(navDdCloseTimer);
      const r = navBtn.getBoundingClientRect();
      navDd.style.top  = (r.bottom + 8) + 'px';
      navDd.style.left = r.left + 'px';
      navDd.classList.add('open');
      navBtn.classList.add('open');
      navBtn.setAttribute('aria-expanded', 'true');
    }
    function closeDd() {
      navDd.classList.remove('open');
      navBtn.classList.remove('open');
      navBtn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseDd() { navDdCloseTimer = setTimeout(closeDd, 200); }
    navBtn.addEventListener('mouseenter', openDd);
    navBtn.addEventListener('mouseleave', scheduleCloseDd);
    navDd.addEventListener('mouseenter', () => clearTimeout(navDdCloseTimer));
    navDd.addEventListener('mouseleave', scheduleCloseDd);
    navBtn.addEventListener('click', e => { if (navDd.classList.contains('open')) return; e.preventDefault(); openDd(); });
    document.addEventListener('click', closeDd);
    navDd.addEventListener('click', e => e.stopPropagation());
  }

  const mdetHamburgerBtn = document.getElementById('mdet-nav-hamburger-btn');
  const mdetMobileMenu   = document.getElementById('mdet-nav-mobile-menu');
  const mdetMobileClose  = document.getElementById('mdet-nav-mobile-close-btn');
  if (mdetHamburgerBtn && mdetMobileMenu) {
    function openMdetMobileMenu() {
      mdetMobileMenu.classList.add('open');
      mdetHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMdetMobileMenu() {
      mdetMobileMenu.classList.remove('open');
      mdetHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    mdetHamburgerBtn.addEventListener('click', openMdetMobileMenu);
    if (mdetMobileClose) mdetMobileClose.addEventListener('click', closeMdetMobileMenu);
    mdetMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMdetMobileMenu));
  }

  // ── Archived Gallery carousel ─────────────────────────────
  // rAF animation instead of native smooth scrolling: scroll-snap containers
  // ignore programmatic smooth scrolls in several engines.
  const track = document.getElementById('evd-car-track');
  if (track) {
    const step = () => track.querySelector('.evd-car-card').getBoundingClientRect().width + 24;
    let animTimer = null;
    function animateTo(target) {
      const start = track.scrollLeft;
      const delta = target - start;
      const t0 = performance.now();
      track.style.scrollSnapType = 'none';
      track.style.scrollBehavior = 'auto'; /* let the JS easing own the motion */
      clearInterval(animTimer);
      animTimer = setInterval(() => {
        const p = Math.min(1, (performance.now() - t0) / 400);
        track.scrollLeft = start + delta * (1 - Math.pow(1 - p, 3));
        if (p >= 1) {
          clearInterval(animTimer);
          track.style.scrollSnapType = '';
          track.style.scrollBehavior = '';
        }
      }, 16);
    }
    function go(dir) {
      const idx = Math.round(track.scrollLeft / step()) + dir;
      const max = track.scrollWidth - track.clientWidth;
      animateTo(Math.max(0, Math.min(idx * step(), max)));
    }
    document.querySelector('.evd-car-prev').addEventListener('click', () => go(-1));
    document.querySelector('.evd-car-next').addEventListener('click', () => go(1));
  }
})();
</script>
