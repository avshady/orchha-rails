<%# About Sabhyata Foundation page — Figma 3278-10903, horizontal scroll-jacking, 3 panels %>
<% nav = (@home['nav'] || {})
   dd  = nav['discoverDropdown'] || []

   about_italic = @page['aboutHeadingItalic'].presence || 'About'
   about_rest   = @page['aboutHeadingRest'].presence   || 'Sabhyata Foundation'
   about_paras  = @page['aboutParagraphs'].presence    || [
     "Established in June 2018 under Section 8 of the Indian Companies Act, 2013, Sabhyata Foundation is committed to preserving and promoting India’s cultural and heritage ecosystem through sustainable development, responsible tourism and immersive visitor experiences.",
     "The Foundation works towards developing world-class heritage infrastructure, improving visitor amenities and curating meaningful cultural experiences that deepen public engagement with India’s rich history and living traditions. Through collaborative partnerships and community-focused initiatives, Sabhyata Foundation aims to make heritage more accessible, engaging and relevant for future generations.",
     "As a Smarak Sarathi under the Government of India’s Adopt a Heritage 2.0 initiative, the Foundation currently supports these iconic Delhi landmarks - Purana Qila, Safdarjung Tomb, Humayun’s Tomb and Mehrauli Archaeological Park. It has also been actively associated with Red Fort, a UNESCO World Heritage Site, in partnership with Dalmia Bharat Ltd. under the Adopt a Heritage 1.0 initiative.",
     "At its core, Sabhyata Foundation believes that heritage is a shared legacy - one that must be protected, celebrated and continually reimagined to inspire generations to come."
   ]
   sites_italic = @page['sitesHeadingItalic'].presence || 'Other'
   sites_rest   = @page['sitesHeadingRest'].presence   || 'Sabhyata Sites'
   sites_body   = @page['sitesBody'].presence || "India's monuments are living expressions of its civilisational journey - guardians of stories, craftsmanship, traditions, and collective memory. At Sabhyata Foundation, we believe these heritage sites are more than architectural landmarks; they are cultural ecosystems that connect people with their roots and inspire future generations. Explore these remarkable places not simply as destinations, but as enduring symbols of India's diverse heritage, where every stone, carving, and corridor carries a story waiting to be discovered."
   explore_lbl  = @page['exploreLabel'].presence || 'Explore More'
   explore_url  = @page['exploreUrl'].presence   || 'https://sabhyatafoundation.com/our-monuments/'
   sites        = @page['sites'].presence || [
     { 'name' => 'Mehrauli Archaeological Park', 'image' => '/images/sabhyata_mehrauli.jpg',    'size' => 'tall',  'labelPosition' => 'below' },
     { 'name' => 'Purana Qila',                  'image' => '/images/sabhyata_purana_qila.jpg', 'size' => 'short', 'labelPosition' => 'above' }
   ]
%>

<div class="sticky-hoho"><a href="/hoho">HOHO Service</a></div>

<%# Fixed nav — outside scroll wrapper %>
<div class="mdet-nav-wrap">
  <nav class="mdet-navbar">
    <div class="mdet-nav-links">
      <div class="mdet-nav-discover">
        <a href="/" class="mdet-nav-link mdet-discover-btn" aria-expanded="false" aria-haspopup="true">
          Discover Orchha
          <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <a href="/plan-your-visit" class="mdet-nav-link">Plan Your Visit</a>
      <a href="/news"            class="mdet-nav-link">News</a>
      <a href="/support-us"      class="mdet-nav-link">Support Us</a>
      <a href="/sabhyata"        class="mdet-nav-link">Sabhyata Foundation</a>
    </div>
    <button class="mdet-nav-hamburger" id="mdet-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="mdet-book-btn">Book Tickets</a>
  </nav>

  <div class="mdet-nav-mobile-menu" id="mdet-nav-mobile-menu">
    <button class="mdet-nav-mobile-close" id="mdet-nav-mobile-close-btn" aria-label="Close menu">
      <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <div class="mdet-nav-mobile-links">
      <a href="/" class="mdet-nav-mobile-link">Home</a>
      <% dd.each do |item| %>
      <a href="<%= item['url'] %>" class="mdet-nav-mobile-link"><%= item['label'] %></a>
      <% end %>
      <a href="/plan-your-visit" class="mdet-nav-mobile-link">Plan Your Visit</a>
      <a href="/news" class="mdet-nav-mobile-link">News</a>
      <a href="/support-us" class="mdet-nav-mobile-link">Support Us</a>
      <a href="/sabhyata" class="mdet-nav-mobile-link">Sabhyata Foundation</a>
    </div>
    <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="mdet-nav-mobile-book-btn">Book Tickets</a>
  </div>

  <%# Discover dropdown — kept outside .mdet-navbar because its backdrop-filter
      creates a new containing block for position:fixed descendants %>
  <div class="mdet-nav-dropdown" role="menu">
    <% dd.each do |item| %>
    <a href="<%= item['url'] %>" class="mdet-nav-dd-item" role="menuitem"><%= item['label'] %></a>
    <% end %>
  </div>
</div>

<div class="mdet-wrapper sab-wrapper" data-panels="3">
  <div class="mdet-sticky">
    <div class="mdet-track" id="mdet-track">

      <%# ══ PANEL 1 — ABOUT SABHYATA FOUNDATION ══════════════ %>
      <section class="mdet-panel sab-panel">
        <div class="sab-about-heading-col">
          <h1 class="sab-heading sab-heading-xl"><em><%= about_italic %></em><br><%= about_rest %></h1>
        </div>
        <div class="sab-about-body-col">
          <% about_paras.each do |para| %>
          <p class="sab-body"><%= para %></p>
          <% end %>
        </div>

        <div class="mdet-scroll-hint" id="mdet-scroll-hint">
          <span>Scroll to explore</span>
          <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </section>

      <%# ══ PANEL 2 — OTHER SABHYATA SITES ═════════════════════ %>
      <section class="mdet-panel sab-panel sab-panel-sites">
        <div class="sab-sites-text">
          <h2 class="sab-heading sab-heading-xl"><em><%= sites_italic %></em><br><%= sites_rest %></h2>
          <% if sites_body %>
          <p class="sab-body sab-sites-body"><%= sites_body %></p>
          <% end %>
          <a href="<%= explore_url %>" target="_blank" rel="noopener" class="sab-explore-btn"><%= explore_lbl %></a>
        </div>
      </section>

      <%# ══ PANEL 3 — SITE PHOTOS ══════════════════════════════ %>
      <section class="mdet-panel sab-panel sab-panel-photos">
        <% sites.each do |site| %>
        <div class="sab-site-col sab-site-col-<%= site['size'] == 'short' ? 'short' : 'tall' %>">
          <% if site['labelPosition'] == 'above' %>
          <span class="sab-site-name sab-site-name-above"><%= site['name'] %></span>
          <% end %>
          <div class="sab-site-photo sab-site-photo-<%= site['size'] == 'short' ? 'short' : 'tall' %>">
            <img src="<%= site['image'] %>" alt="<%= site['name'] %> — Sabhyata Foundation heritage site">
          </div>
          <% if site['labelPosition'] != 'above' %>
          <span class="sab-site-name sab-site-name-below"><%= site['name'] %></span>
          <% end %>
        </div>
        <% end %>
      </section>

    </div><%# /mdet-track %>
  </div><%# /mdet-sticky %>
</div><%# /mdet-wrapper %>

<script>
(function() {
  const isMobile = window.matchMedia('(max-width: 900px)').matches;

  const wrapper = document.querySelector('.sab-wrapper');
  const sticky  = document.querySelector('.mdet-sticky');
  const hint    = document.getElementById('mdet-scroll-hint');

  if (wrapper && sticky && !isMobile) {
    const panels = parseFloat(wrapper.dataset.panels || '3');
    wrapper.style.height = (panels * 100) + 'vh';

    function updateHoriz() {
      const wrapperTop  = wrapper.offsetTop;
      const totalScroll = wrapper.offsetHeight - window.innerHeight;
      const progress    = Math.max(0, Math.min(1, (window.scrollY - wrapperTop) / totalScroll));
      const maxScroll   = sticky.scrollWidth - window.innerWidth;
      sticky.scrollLeft = progress * maxScroll;
      if (hint) hint.style.opacity = progress > 0.01 ? '0' : '1';
    }

    window.addEventListener('scroll', updateHoriz, { passive: true });
    updateHoriz();
  }

  // ── Navbar dropdown ───────────────────────────────────────
  const btn = document.querySelector('.mdet-discover-btn');
  const dd  = document.querySelector('.mdet-nav-dropdown');
  if (btn && dd) {
    let ddCloseTimer;
    function openDd()  {
      clearTimeout(ddCloseTimer);
      const r = btn.getBoundingClientRect();
      dd.style.top  = (r.bottom + 8) + 'px';
      dd.style.left = r.left + 'px';
      dd.classList.add('open');
      btn.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    }
    function closeDd() {
      dd.classList.remove('open');
      btn.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseDd() { ddCloseTimer = setTimeout(closeDd, 200); }
    btn.addEventListener('mouseenter', openDd);
    btn.addEventListener('mouseleave', scheduleCloseDd);
    dd.addEventListener('mouseenter', () => clearTimeout(ddCloseTimer));
    dd.addEventListener('mouseleave', scheduleCloseDd);
    btn.addEventListener('click', e => { if (dd.classList.contains('open')) return; e.preventDefault(); openDd(); });
    document.addEventListener('click', closeDd);
    dd.addEventListener('click', e => e.stopPropagation());
  }

  // ── Mobile hamburger menu ─────────────────────────────────
  const mdetHamburgerBtn = document.getElementById('mdet-nav-hamburger-btn');
  const mdetMobileMenu   = document.getElementById('mdet-nav-mobile-menu');
  const mdetMobileClose  = document.getElementById('mdet-nav-mobile-close-btn');
  if (mdetHamburgerBtn && mdetMobileMenu) {
    function openMdetMobileMenu() {
      mdetMobileMenu.classList.add('open');
      mdetHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMdetMobileMenu() {
      mdetMobileMenu.classList.remove('open');
      mdetHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    mdetHamburgerBtn.addEventListener('click', openMdetMobileMenu);
    if (mdetMobileClose) mdetMobileClose.addEventListener('click', closeMdetMobileMenu);
    mdetMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMdetMobileMenu));
  }
})();
</script>
