<%# Celebrate Orchha (Events) page %>
<% ft       = (@home['footer'] || {})
   ft_links = ft['links'] || []
   vs       = @home['visit'] || {}
   nav      = @home['nav']   || {}
   dd       = nav['discoverDropdown'] || []
   cats     = @page['filterCategories'] || [
     {'label'=>'ALL','value'=>'all'},
     {'label'=>'ONGOING','value'=>'ongoing'},
     {'label'=>'UPCOMING','value'=>'upcoming'},
     {'label'=>'ARCHIVES','value'=>'archives'}
   ]
   months = @items.map { |e| e['month'] }.reject(&:blank?).uniq
%>

<%# Sticky HOHO button %>
<div class="sticky-hoho">
  <a href="https://ho-hoservices.netlify.app/" target="_blank" rel="noopener">HOHO Service</a>
</div>

<div class="evt-page">

  <%# ── NAVBAR ─────────────────────────────────────────── %>
  <div class="mon-nav-wrap">
    <nav class="hist-navbar">
      <div class="nav-links">
        <div class="nav-discover">
          <a href="/" class="hist-nav-link hist-nav-discover-btn" aria-expanded="false" aria-haspopup="true">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <a href="/plan-your-visit" class="hist-nav-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-link">News</a>
        <a href="/support-us" class="hist-nav-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-link">Sabhyata Foundation</a>
      </div>
      <button class="hist-nav-hamburger" id="hist-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="/book-tickets" class="hist-book-btn">Book Tickets</a>
    </nav>

    <div class="hist-nav-mobile-menu" id="hist-nav-mobile-menu">
      <button class="hist-nav-mobile-close" id="hist-nav-mobile-close-btn" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="hist-nav-mobile-links">
        <% dd.each do |item| %>
        <a href="<%= item['url'] %>" class="hist-nav-mobile-link"><%= item['label'] %></a>
        <% end %>
        <a href="/plan-your-visit" class="hist-nav-mobile-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-mobile-link">News</a>
        <a href="/support-us" class="hist-nav-mobile-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-mobile-link">Sabhyata Foundation</a>
      </div>
      <a href="/book-tickets" class="hist-nav-mobile-book-btn">Book Tickets</a>
    </div>

    <%# Discover dropdown — kept outside .hist-navbar because its backdrop-filter
        creates a new containing block for position:fixed descendants %>
    <div class="hist-nav-dropdown" role="menu">
      <% dd.each do |item| %>
      <a href="<%= item['url'] %>" class="hist-nav-dropdown-item" role="menuitem"><%= item['label'] %></a>
      <% end %>
    </div>
  </div>

  <%# ── HEADER ─────────────────────────────────────────── %>
  <header class="evt-header">
    <h1 class="evt-heading"><%= @page['heading'] || 'Celebrate Orchha' %></h1>
    <p class="evt-subheading"><%= @page['subheading'] || 'Discover the festivals, cultural gatherings, and seasonal celebrations that showcase the living traditions of Orchha.' %></p>
  </header>

  <%# ── EVENTS SECTION ────────────────────────────────────── %>
  <section class="evt-section">

    <%# Filter row %>
    <div class="evt-filter-row">
      <div class="evt-filter-tabs" role="tablist">
        <% cats.each_with_index do |cat, i| %>
        <button class="evt-tab <%= i == 0 ? 'active' : '' %>"
                data-cat="<%= cat['value'] %>"
                role="tab"
                aria-selected="<%= i == 0 ? 'true' : 'false' %>">
          <%= cat['label'] %>
        </button>
        <% end %>
      </div>
      <div class="evt-month-filter">
        <select class="evt-month-select" id="evt-month-select" aria-label="Filter by month">
          <option value="all">Month</option>
          <% months.each do |m| %>
          <option value="<%= m %>"><%= m.capitalize %></option>
          <% end %>
        </select>
        <svg class="evt-month-chevron" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1l4 4 4-4" stroke="#6e1603" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <%# Cards grid %>
    <div class="evt-cards" id="evt-cards">
      <% @items.each do |ev| %>
      <a href="<%= ev['detailPage'] || '#' %>" class="evt-card"
         data-cat="<%= ev['category'] || 'upcoming' %>"
         data-month="<%= ev['month'] %>">
        <div class="evt-card-photo">
          <img src="<%= ev['image'] %>" alt="<%= ev['name'] %>" loading="lazy">
          <div class="evt-card-logos">
            <img src="/images/mpt_logo.png" class="evt-logo-mpt" alt="MPT">
            <img src="/images/incredible_india.png" class="evt-logo-ii" alt="Incredible India">
          </div>
        </div>
        <div class="evt-card-body">
          <h3 class="evt-card-name"><%= ev['name'] %></h3>
          <p class="evt-card-date"><%= ev['date'] %></p>
          <span class="evt-card-explore">
            Explore
            <svg viewBox="0 0 16 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 5h13M10 1l4 4-4 4" stroke="#535353" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>
      <% end %>
    </div>

    <%# Empty state %>
    <p class="evt-empty" id="evt-empty" style="display:none">No events found.</p>

  </section>

  <%# ── VISIT ORCHHA (reused) ──────────────────────────── %>
  <div class="visit-wrap">
    <div class="visit-section">
      <div class="visit-bg-img" style="background-image: url('<%= vs['bgImage'] || '/images/visit_orchha_bg.jpg' %>')"></div>
      <div class="visit-content">
        <h2 class="visit-heading"><em>Visit</em> Orchha</h2>
        <div class="visit-links">
          <% (vs['links'] || [{'label'=>'How to Reach Orchha','url'=>'/reach'},{'label'=>'Travel Options','url'=>'/travel'},{'label'=>'Stay Options','url'=>'/stay'}]).each do |lnk| %>
          <a href="<%= lnk['url'] %>" class="visit-link"><%= lnk['label'] %></a>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── FOOTER ─────────────────────────────────────────── %>
  <footer class="footer">
    <div class="footer-container">
      <div class="footer-inner">
        <div class="footer-links">
          <% ft_links.each do |lnk| %>
          <a href="<%= lnk['url'] %>" class="footer-link"><%= lnk['label'] %></a>
          <% end %>
        </div>
        <div class="footer-logos">
          <img src="/images/incredible_india.png" alt="Incredible India" class="footer-logo-ii">
          <img src="/images/mpt_logo.png" alt="MPTDC" class="footer-logo-mptdc">
          <img src="/images/footer_logo_sabhyata.png" alt="Sabhyata Foundation" class="footer-logo-sabhyata">
        </div>
        <div class="footer-map">
          <img src="/images/footer_map.jpg" alt="Orchha map">
        </div>
      </div>
      <hr class="footer-divider">
      <div class="footer-bottom">
        <span class="footer-copy"><%= ft['copyright'] || '@2026ORCHHA' %></span>
        <span class="footer-copy"><%= ft['org'] || 'SABHYATA Foundation' %></span>
      </div>
    </div>
  </footer>

</div><%# /.evt-page %>

<script>
  // ── Navbar dropdown ───────────────────────────────────────
  const evtBtn = document.querySelector('.hist-nav-discover-btn');
  const evtDd  = document.querySelector('.hist-nav-dropdown');
  if (evtBtn && evtDd) {
    let evtDdCloseTimer;
    function openEvtDd() {
      clearTimeout(evtDdCloseTimer);
      const r = evtBtn.getBoundingClientRect();
      evtDd.style.top  = (r.bottom + 8) + 'px';
      evtDd.style.left = r.left + 'px';
      evtDd.classList.add('open');
      evtBtn.classList.add('open');
      evtBtn.setAttribute('aria-expanded', 'true');
    }
    function closeEvtDd() {
      evtDd.classList.remove('open');
      evtBtn.classList.remove('open');
      evtBtn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseEvtDd() { evtDdCloseTimer = setTimeout(closeEvtDd, 200); }
    evtBtn.addEventListener('mouseenter', openEvtDd);
    evtBtn.addEventListener('mouseleave', scheduleCloseEvtDd);
    evtDd.addEventListener('mouseenter', () => clearTimeout(evtDdCloseTimer));
    evtDd.addEventListener('mouseleave', scheduleCloseEvtDd);
    evtBtn.addEventListener('click', e => { if (evtDd.classList.contains('open')) return; e.preventDefault(); openEvtDd(); });
    document.addEventListener('click', closeEvtDd);
    evtDd.addEventListener('click', e => e.stopPropagation());
  }

  // ── Mobile hamburger menu ───────────────────────────────────
  const histHamburgerBtn = document.getElementById('hist-nav-hamburger-btn');
  const histMobileMenu   = document.getElementById('hist-nav-mobile-menu');
  const histMobileClose  = document.getElementById('hist-nav-mobile-close-btn');
  if (histHamburgerBtn && histMobileMenu) {
    function openHistMobileMenu() {
      histMobileMenu.classList.add('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeHistMobileMenu() {
      histMobileMenu.classList.remove('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    histHamburgerBtn.addEventListener('click', openHistMobileMenu);
    if (histMobileClose) histMobileClose.addEventListener('click', closeHistMobileMenu);
    histMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeHistMobileMenu));
  }

  // ── Filter by category + month ───────────────────────────────
  const evtCards = Array.from(document.querySelectorAll('.evt-card'));
  const evtTabs  = Array.from(document.querySelectorAll('.evt-tab'));
  const evtEmpty = document.getElementById('evt-empty');
  const evtMonthSelect = document.getElementById('evt-month-select');
  let evtActiveCat = 'all';
  let evtActiveMonth = 'all';

  function applyEvtFilter() {
    let visible = 0;
    evtCards.forEach(card => {
      const cat   = card.dataset.cat;
      const month = card.dataset.month;
      const catOk   = evtActiveCat === 'all' || cat === evtActiveCat;
      const monthOk = evtActiveMonth === 'all' || month === evtActiveMonth;
      const show = catOk && monthOk;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    evtEmpty.style.display = visible === 0 ? 'block' : 'none';
  }

  evtTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      evtTabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected','true');
      evtActiveCat = tab.dataset.cat;
      applyEvtFilter();
    });
  });

  if (evtMonthSelect) {
    evtMonthSelect.addEventListener('change', e => {
      evtActiveMonth = e.target.value;
      applyEvtFilter();
    });
  }
</script>
