<%# Hop-on Hop-off Services — matches the Figma design %>
<% ft       = (@home['footer'] || {})
   ft_links = ft['links'] || []
   nav      = @home['nav']   || {}
   dd       = nav['discoverDropdown'] || []
   vs       = @home['visit'] || {}
   services = @services.presence || []
%>

<%# Sticky HOHO button %>
<div class="sticky-hoho">
  <a href="/hoho">HOHO Service</a>
</div>

<div class="ff-page">

  <%# ── NAVBAR ─────────────────────────────────────────── %>
  <div class="mon-nav-wrap">
    <nav class="hist-navbar">
      <div class="nav-links">
        <div class="nav-discover">
          <a href="/" class="hist-nav-link hist-nav-discover-btn" aria-expanded="false" aria-haspopup="true">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <a href="/plan-your-visit" class="hist-nav-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-link">News</a>
        <a href="/support-us" class="hist-nav-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-link">Sabhyata Foundation</a>
      </div>
      <button class="hist-nav-hamburger" id="hist-nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-book-btn">Book Tickets</a>
    </nav>

    <div class="hist-nav-mobile-menu" id="hist-nav-mobile-menu">
      <button class="hist-nav-mobile-close" id="hist-nav-mobile-close-btn" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="hist-nav-mobile-links">
        <% dd.each do |item| %>
        <a href="<%= item['url'] %>" class="hist-nav-mobile-link"><%= item['label'] %></a>
        <% end %>
        <a href="/plan-your-visit" class="hist-nav-mobile-link">Plan Your Visit</a>
        <a href="/news" class="hist-nav-mobile-link">News</a>
        <a href="/support-us" class="hist-nav-mobile-link">Support Us</a>
        <a href="/sabhyata" class="hist-nav-mobile-link">Sabhyata Foundation</a>
      </div>
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="hist-nav-mobile-book-btn">Book Tickets</a>
    </div>

    <div class="hist-nav-dropdown" role="menu">
      <% dd.each do |item| %>
      <a href="<%= item['url'] %>" class="hist-nav-dropdown-item" role="menuitem"><%= item['label'] %></a>
      <% end %>
    </div>
  </div>

  <%# ── HEADER ─────────────────────────────────────────── %>
  <header class="ff-header hoho-header">
    <h1 class="ff-heading">Hop-on Hop-off Services</h1>
    <p class="ff-subheading">Explore Orchha effortlessly with eco-friendly Ho-Ho Services, connecting major monuments, temples, cultural attractions, and riverside landmarks through convenient Hop-On Hop-Off transportation.</p>
  </header>

  <%# ── SERVICE CARDS ─────────────────────────────────────── %>
  <section class="hoho-cards-wrap">
    <div class="hoho-cards">
      <% services.each do |s| %>
      <div class="hoho-card">
        <div class="hoho-card-photo">
          <img src="<%= s['image'] %>" alt="<%= s['name'] %>" loading="lazy">
          <div class="hoho-card-tag">
            <span class="hoho-tag-icon">
              <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="7" width="22" height="14" rx="3" stroke="#6e1603" stroke-width="1.7"/><path d="M3 13h22M9 21v2M19 21v2" stroke="#6e1603" stroke-width="1.7" stroke-linecap="round"/><circle cx="8.5" cy="17" r="1.4" fill="#6e1603"/><circle cx="19.5" cy="17" r="1.4" fill="#6e1603"/></svg>
            </span>
            <span class="hoho-tag-label"><%= s['name'] %></span>
          </div>
        </div>

        <div class="hoho-card-body">
          <div class="hoho-features">
            <% (s['features'] || []).each_with_index do |feat, i| %>
            <% if i > 0 %><span class="hoho-divider"></span><% end %>
            <div class="hoho-feature">
              <%= hoho_feature_icon(feat) %>
              <span><%= feat %></span>
            </div>
            <% end %>
          </div>

          <hr class="hoho-hr">

          <div class="hoho-stats">
            <div class="hoho-stat">
              <div class="hoho-stat-value"><%= s['price'] %></div>
              <div class="hoho-stat-label">per person</div>
            </div>
            <span class="hoho-divider hoho-divider-tall"></span>
            <div class="hoho-stat">
              <div class="hoho-stat-value"><%= s['distance'] %></div>
              <div class="hoho-stat-label">Total Distance</div>
            </div>
            <span class="hoho-divider hoho-divider-tall"></span>
            <div class="hoho-stat">
              <div class="hoho-stat-value"><%= s['duration'] %></div>
              <div class="hoho-stat-label">Total Duration</div>
            </div>
          </div>

          <a href="<%= s['bookUrl'].presence || 'https://www.tezticket.com/tickets/buy?event=SF' %>" target="_blank" rel="noopener" class="hoho-book-btn">
            Book Now
            <svg viewBox="0 0 24 10" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 5h20M16 1l4 4-4 4" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>

          <% if s['detailText'].present? %>
          <div class="hoho-detail-item">
            <button type="button" class="hoho-detail-toggle" data-acc-toggle>
              <span class="hoho-detail-toggle-txt hoho-detail-toggle-txt--closed">View detailed route, distance &amp; travel time</span>
              <span class="hoho-detail-toggle-txt hoho-detail-toggle-txt--open">Close detailed route, distance &amp; travel time</span>
              <svg class="hoho-detail-chevron" viewBox="0 0 16 10" fill="none"><path d="M1 1l7 7 7-7" stroke="#1a0a00" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="hoho-detail-body">
              <div class="hoho-detail-body-inner">
                <% if s['stops'].present? %>
                <div class="hoho-route-head">
                  <p class="hoho-route-name"><strong>Route:</strong> <%= s['routeName'] %></p>
                  <p class="hoho-route-subtitle"><%= s['routeSubtitle'] %></p>
                </div>
                <ol class="hoho-stops-timeline">
                  <% s['stops'].each do |stop| %>
                  <li class="hoho-stop-row">
                    <div class="hoho-stop-rail">
                      <span class="hoho-stop-icon" aria-hidden="true">
                        <svg viewBox="0 0 20 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 23S2 14.6 2 9a8 8 0 1 1 16 0c0 5.6-8 14-8 14Z" fill="#a8391c"/><circle cx="10" cy="9" r="3.2" fill="#fff"/></svg>
                      </span>
                    </div>
                    <div class="hoho-stop-content">
                      <% if stop['distanceFromPrev'].present? %>
                      <div class="hoho-segment-chip">
                        <svg class="hoho-segment-icon" viewBox="0 0 12 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M6 1v18M6 1 2 5M6 1l4 4M6 19l-4-4M6 19l4-4" stroke="#6e1603" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span class="hoho-segment-label">Distance:</span>
                        <span class="hoho-segment-value"><%= stop['distanceFromPrev'] %></span>
                        <span class="hoho-segment-dot">&bull;</span>
                        <span class="hoho-segment-label">Duration:</span>
                        <span class="hoho-segment-value"><%= stop['durationFromPrev'] %></span>
                      </div>
                      <% end %>
                      <div class="hoho-stop-main">
                        <% if stop['image'].present? %>
                        <img class="hoho-stop-photo" src="<%= stop['image'] %>" alt="<%= stop['name'] %>" loading="lazy">
                        <% end %>
                        <span class="hoho-stop-name"><%= stop['name'] %></span>
                      </div>
                    </div>
                  </li>
                  <% end %>
                </ol>
                <% else %>
                <p><%= s['detailText'] %></p>
                <% end %>
              </div>
            </div>
          </div>
          <% end %>
        </div>
      </div>
      <% end %>
    </div>

    <div class="ff-translate hoho-translate" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" width="22" height="22"><path d="M4 5h9M8.5 3v2.5M6 8c1 2.5 3 4.5 6 6M11 8c-.7 3-3 6-7 7.5M14 21l4-9 4 9M15.5 18h5" stroke="#1a0a00" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Translate</span>
      <svg viewBox="0 0 10 6" fill="none" width="10" height="6"><path d="M1 1l4 4 4-4" stroke="#1a0a00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
  </section>

  <%# ── VISIT ORCHHA (reused) ──────────────────────────── %>
  <div class="visit-wrap">
    <div class="visit-section">
      <div class="visit-bg-img" style="background-image: url('<%= vs['bgImage'] || '/images/visit_orchha_bg.jpg' %>')"></div>
      <div class="visit-content">
        <h2 class="visit-heading"><em>Visit</em> Orchha</h2>
        <div class="visit-links">
          <% (vs['links'] || [{'label'=>'How to Reach Orchha','url'=>'/reach'},{'label'=>'Travel Options','url'=>'/travel'},{'label'=>'Stay Options','url'=>'/stay'}]).each do |lnk| %>
          <a href="<%= lnk['url'] %>" class="visit-link"><%= lnk['label'] %></a>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── FOOTER ─────────────────────────────────────────── %>
  <footer class="footer">
    <div class="footer-container">
      <div class="footer-inner">
        <div class="footer-links">
          <% ft_links.each do |lnk| %>
          <a href="<%= lnk['url'] %>" class="footer-link"><%= lnk['label'] %></a>
          <% end %>
        </div>
        <div class="footer-logos">
          <img src="/images/incredible_india.png" alt="Incredible India" class="footer-logo-ii">
          <img src="/images/mpt_logo.png" alt="MPTDC" class="footer-logo-mptdc">
          <img src="/images/footer_logo_sabhyata.png" alt="Sabhyata Foundation" class="footer-logo-sabhyata">
        </div>
        <div class="footer-map">
          <img src="/images/footer_map.jpg" alt="Orchha map">
        </div>
      </div>
      <hr class="footer-divider">
      <div class="footer-bottom">
        <span class="footer-copy"><%= ft['copyright'] || '@2026ORCHHA' %></span>
        <span class="footer-copy"><%= ft['org'] || 'SABHYATA Foundation' %></span>
      </div>
    </div>
  </footer>

</div><%# /.ff-page %>

<script>
  // ── Navbar dropdown ───────────────────────────────────────
  const hohoBtn = document.querySelector('.hist-nav-discover-btn');
  const hohoDd  = document.querySelector('.hist-nav-dropdown');
  if (hohoBtn && hohoDd) {
    let hohoCloseTimer;
    function openHohoDd() {
      clearTimeout(hohoCloseTimer);
      const r = hohoBtn.getBoundingClientRect();
      hohoDd.style.top  = (r.bottom + 8) + 'px';
      hohoDd.style.left = r.left + 'px';
      hohoDd.classList.add('open');
      hohoBtn.classList.add('open');
      hohoBtn.setAttribute('aria-expanded', 'true');
    }
    function closeHohoDd() {
      hohoDd.classList.remove('open');
      hohoBtn.classList.remove('open');
      hohoBtn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseHohoDd() { hohoCloseTimer = setTimeout(closeHohoDd, 200); }
    hohoBtn.addEventListener('mouseenter', openHohoDd);
    hohoBtn.addEventListener('mouseleave', scheduleCloseHohoDd);
    hohoDd.addEventListener('mouseenter', () => clearTimeout(hohoCloseTimer));
    hohoDd.addEventListener('mouseleave', scheduleCloseHohoDd);
    hohoBtn.addEventListener('click', e => { if (hohoDd.classList.contains('open')) return; e.preventDefault(); openHohoDd(); });
    document.addEventListener('click', closeHohoDd);
    hohoDd.addEventListener('click', e => e.stopPropagation());
  }

  // ── Mobile hamburger menu ───────────────────────────────────
  const histHamburgerBtn = document.getElementById('hist-nav-hamburger-btn');
  const histMobileMenu   = document.getElementById('hist-nav-mobile-menu');
  const histMobileClose  = document.getElementById('hist-nav-mobile-close-btn');
  if (histHamburgerBtn && histMobileMenu) {
    function openHistMobileMenu() {
      histMobileMenu.classList.add('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeHistMobileMenu() {
      histMobileMenu.classList.remove('open');
      histHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    histHamburgerBtn.addEventListener('click', openHistMobileMenu);
    if (histMobileClose) histMobileClose.addEventListener('click', closeHistMobileMenu);
    histMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeHistMobileMenu));
  }

  // ── Route detail accordion ─────────────────────────────────
  document.querySelectorAll('[data-acc-toggle]').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.hoho-detail-item').classList.toggle('open');
    });
  });
</script>
