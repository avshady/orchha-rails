<%# Floating QR scanner — mobile only (≤900px). Camera + BarcodeDetector,
    falls back to lazily-loaded /js/jsqr.min.js on browsers without it. %>
<button class="qrs-fab" id="qrs-fab" aria-label="Scan QR code">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="3" width="7" height="7" rx="1"/>
    <rect x="14" y="3" width="7" height="7" rx="1"/>
    <rect x="3" y="14" width="7" height="7" rx="1"/>
    <path d="M14 14h3v3h-3zM20 14h1M14 20h1M20 20h1M17.5 17.5v3.5"/>
  </svg>
</button>

<div class="qrs-overlay" id="qrs-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="QR code scanner">
  <div class="qrs-top">
    <span class="qrs-title">Scan QR Code</span>
    <button class="qrs-close" id="qrs-close" aria-label="Close scanner">
      <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
  </div>
  <div class="qrs-viewport">
    <video id="qrs-video" playsinline muted></video>
    <div class="qrs-frame">
      <span class="qrs-c qrs-c1"></span><span class="qrs-c qrs-c2"></span>
      <span class="qrs-c qrs-c3"></span><span class="qrs-c qrs-c4"></span>
      <div class="qrs-beam"></div>
    </div>
  </div>
  <p class="qrs-status" id="qrs-status">Point your camera at a QR code</p>
  <div class="qrs-result" id="qrs-result" hidden>
    <p class="qrs-result-text" id="qrs-result-text"></p>
    <a class="qrs-btn" id="qrs-result-open" target="_blank" rel="noopener" hidden>Open Link</a>
    <button class="qrs-btn qrs-btn-ghost" id="qrs-rescan">Scan Again</button>
  </div>
  <canvas id="qrs-canvas" hidden></canvas>
</div>

<script>
  (function () {
    const fab     = document.getElementById('qrs-fab');
    const overlay = document.getElementById('qrs-overlay');
    if (!fab || !overlay) return;
    const video   = document.getElementById('qrs-video');
    const canvas  = document.getElementById('qrs-canvas');
    const status  = document.getElementById('qrs-status');
    const result  = document.getElementById('qrs-result');
    const resText = document.getElementById('qrs-result-text');
    const resOpen = document.getElementById('qrs-result-open');

    // Lift the button above the fixed bottom action bar on monument/trail pages.
    if (document.querySelector('.mdet-action-tabs')) fab.classList.add('qrs-fab-raised');

    let stream = null, scanning = false, jsqrReady = null;
    const hasDetector = 'BarcodeDetector' in window;

    function loadJsQR() {
      if (window.jsQR) return Promise.resolve();
      if (!jsqrReady) {
        jsqrReady = new Promise((res, rej) => {
          const s = document.createElement('script');
          s.src = '/js/jsqr.min.js';
          s.onload = res;
          s.onerror = rej;
          document.head.appendChild(s);
        });
      }
      return jsqrReady;
    }

    async function openScanner() {
      overlay.classList.add('open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      result.hidden = true;
      status.textContent = 'Starting camera…';
      try {
        stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: 'environment' }, audio: false
        });
        video.srcObject = stream;
        await video.play();
        status.textContent = 'Point your camera at a QR code';
        scanning = true;
        if (hasDetector) {
          detectLoop(new BarcodeDetector({ formats: ['qr_code'] }));
        } else {
          await loadJsQR();
          jsqrLoop();
        }
      } catch (err) {
        status.textContent = err.name === 'NotAllowedError'
          ? 'Camera access was denied. Allow camera permission to scan.'
          : 'Could not start the camera on this device.';
      }
    }

    function closeScanner() {
      scanning = false;
      if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
      video.srcObject = null;
      overlay.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    async function detectLoop(detector) {
      if (!scanning) return;
      try {
        const codes = await detector.detect(video);
        if (codes.length) return onScan(codes[0].rawValue);
      } catch (e) { /* frame not ready yet */ }
      requestAnimationFrame(() => detectLoop(detector));
    }

    function jsqrLoop() {
      if (!scanning) return;
      if (video.readyState >= 2) {
        canvas.width  = video.videoWidth;
        canvas.height = video.videoHeight;
        const ctx = canvas.getContext('2d', { willReadFrequently: true });
        ctx.drawImage(video, 0, 0);
        const img  = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const code = window.jsQR(img.data, img.width, img.height);
        if (code && code.data) return onScan(code.data);
      }
      setTimeout(jsqrLoop, 120);
    }

    function onScan(value) {
      scanning = false;
      if (navigator.vibrate) navigator.vibrate(80);
      let url = null;
      try { url = new URL(value); } catch (e) { /* plain text */ }
      if (url && url.origin === location.origin) {
        // Same-site QR (monument plaques etc.) → go straight there.
        closeScanner();
        location.href = url.href;
        return;
      }
      status.textContent = 'QR code found';
      resText.textContent = value;
      if (url && /^https?:$/.test(url.protocol)) {
        resOpen.href = url.href;
        resOpen.hidden = false;
      } else {
        resOpen.hidden = true;
      }
      result.hidden = false;
    }

    document.getElementById('qrs-rescan').addEventListener('click', () => {
      result.hidden = true;
      status.textContent = 'Point your camera at a QR code';
      scanning = true;
      if (hasDetector) detectLoop(new BarcodeDetector({ formats: ['qr_code'] }));
      else jsqrLoop();
    });

    fab.addEventListener('click', openScanner);
    document.getElementById('qrs-close').addEventListener('click', closeScanner);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && overlay.classList.contains('open')) closeScanner();
    });
  })();
</script>
