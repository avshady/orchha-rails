<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
  <h2 class="adm-page-title" style="margin-bottom:0;">Edit: <%= key_label(@block.key) %></h2>
  <div style="display:flex; gap:10px;">
    <a href="<%= edit_admin_content_block_path(@block.key) %>" class="adm-btn adm-btn-outline">Raw JSON</a>
  </div>
</div>

<div class="adm-card">
  <%= form_with url: admin_section_path(@block.key), method: :patch, local: true do %>
    <%= render "fields", data: @data, prefix: "section", depth: 0 %>
    <div style="display:flex; gap:12px; margin-top:20px;">
      <button type="submit" class="adm-btn">Save</button>
      <a href="<%= admin_root_path %>" class="adm-btn adm-btn-outline">Cancel</a>
    </div>
  <% end %>
</div>

<p class="adm-muted">Image fields have a <strong>Browse…</strong> button that opens the media library.</p>
