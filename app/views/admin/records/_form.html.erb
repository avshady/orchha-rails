<%# Auto-derived form: field types come from the record's current values. %>
<%= form_with url: url, method: method, local: true do %>
  <% record.each do |field, value| %>
    <div style="margin-bottom:16px;">
      <label style="display:block; font-size:13px; font-weight:600; color:#6e1603; margin-bottom:5px;">
        <%= field %>
      </label>
      <% case value
         when TrueClass, FalseClass %>
        <select name="record[<%= field %>]" class="adm-input">
          <option value="true"  <%= "selected" if value %>>true (visible / yes)</option>
          <option value="false" <%= "selected" unless value %>>false (hidden / no)</option>
        </select>
      <% when Numeric %>
        <input type="number" step="any" name="record[<%= field %>]" value="<%= value %>" class="adm-input">
      <% when Array, Hash %>
        <textarea name="record[<%= field %>]" spellcheck="false" rows="<%= [[JSON.pretty_generate(value).lines.count + 1, 3].max, 14].min %>"
          class="adm-input adm-json-field" style="font-family:ui-monospace,Menlo,monospace; font-size:12.5px;"><%= JSON.pretty_generate(value) %></textarea>
        <span class="adm-muted" style="font-size:12px;">Structured field — must stay valid JSON.</span>
      <% else %>
        <% str = value.to_s %>
        <% if str.length > 90 || str.include?("\n") %>
          <textarea name="record[<%= field %>]" rows="4" class="adm-input"><%= str %></textarea>
        <% else %>
          <input type="text" name="record[<%= field %>]" value="<%= str %>" class="adm-input"
                 <%= 'data-image-field="1"'.html_safe if field.downcase.include?("image") || field.downcase.include?("photo") %>>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <div style="display:flex; gap:12px; margin-top:20px;">
    <button type="submit" class="adm-btn">Save</button>
    <a href="<%= admin_collection_path(key) %>" class="adm-btn adm-btn-outline">Cancel</a>
  </div>
<% end %>

<div class="adm-card" style="margin-top:18px;">
  <strong style="color:#6e1603; font-size:14px;">Upload an image</strong>
  <p class="adm-muted" style="margin:6px 0 12px;">Upload, then copy the URL into an image field above.</p>
  <input type="file" id="adm-upload-input" accept="image/*,video/*">
  <button type="button" class="adm-btn adm-btn-outline" id="adm-upload-btn" style="margin-left:8px;">Upload</button>
  <div id="adm-upload-result" style="margin-top:10px; font-size:13px; word-break:break-all;"></div>
</div>

<style>
  .adm-input {
    width: 100%; padding: 9px 11px; font-size: 14px; font-family: inherit;
    border: 1px solid #c9b9a6; border-radius: 8px; background: #faf7f2;
  }
  .adm-input:focus { outline: 2px solid #6e1603; border-color: #6e1603; }
</style>

<script>
  document.getElementById('adm-upload-btn').addEventListener('click', async () => {
    const input = document.getElementById('adm-upload-input');
    const result = document.getElementById('adm-upload-result');
    if (!input.files.length) { result.textContent = 'Choose a file first.'; return; }
    const fd = new FormData();
    fd.append('file', input.files[0]);
    result.textContent = 'Uploading…';
    try {
      const resp = await fetch('<%= admin_uploads_path %>', {
        method: 'POST',
        headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
        body: fd
      });
      const data = await resp.json();
      if (!resp.ok) throw new Error(data.error || resp.statusText);
      result.innerHTML = 'Uploaded: <code>' + data.url + '</code> ' +
        '<button type="button" class="adm-btn adm-btn-outline" style="padding:3px 10px; font-size:12px;" ' +
        'onclick="navigator.clipboard.writeText(\'' + data.url + '\')">Copy</button>';
    } catch (e) {
      result.textContent = 'Upload failed: ' + e.message;
    }
  });
</script>
