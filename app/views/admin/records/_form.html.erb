<%# Auto-derived form: field types come from the record's current values. %>
<% new_record = local_assigns.fetch(:new_record, false) %>
<%= form_with url: url, method: method, local: true do %>
  <% record.each do |field, value| %>
    <div style="margin-bottom:16px;">
      <label style="display:block; font-size:13px; font-weight:600; color:#6e1603; margin-bottom:5px;">
        <%= field %>
      </label>
      <% case value
         when TrueClass, FalseClass %>
        <select name="record[<%= field %>]" class="adm-input">
          <option value="true"  <%= "selected" if value %>>true (visible / yes)</option>
          <option value="false" <%= "selected" unless value %>>false (hidden / no)</option>
        </select>
      <% when Numeric %>
        <input type="number" step="any" name="record[<%= field %>]" value="<%= value %>" class="adm-input">
      <% when Array, Hash %>
        <textarea name="record[<%= field %>]" spellcheck="false" rows="<%= [[JSON.pretty_generate(value).lines.count + 1, 3].max, 14].min %>"
          class="adm-input adm-json-field" style="font-family:ui-monospace,Menlo,monospace; font-size:12.5px;"><%= JSON.pretty_generate(value) %></textarea>
        <span class="adm-muted" style="font-size:12px;">Structured field — must stay valid JSON.</span>
      <% else %>
        <% str = value.to_s %>
        <% if str.length > 90 || str.include?("\n") %>
          <textarea name="record[<%= field %>]" rows="4" class="adm-input"><%= str %></textarea>
        <% elsif media_field?(field) %>
          <input type="text" name="record[<%= field %>]" value="<%= str %>" class="adm-input" data-image-field="1">
        <% elsif field == "id" %>
          <input type="text" name="record[<%= field %>]" value="<%= str %>" class="adm-input" id="adm-id-field"
                 <%= "readonly" unless new_record %> style="<%= 'background:#eee6da; color:#7a6a58;' unless new_record %>">
          <span class="adm-muted" style="font-size:12px;">
            <%= new_record ? "Auto-filled from the name — this becomes the page URL." : "The record's URL identifier — locked after creation." %>
          </span>
        <% else %>
          <input type="text" name="record[<%= field %>]" value="<%= str %>" class="adm-input"
                 <%= 'id="adm-name-field"'.html_safe if field == "name" || field == "title" %>>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <div style="display:flex; gap:12px; margin-top:20px;">
    <button type="submit" class="adm-btn">Save</button>
    <a href="<%= admin_collection_path(key) %>" class="adm-btn adm-btn-outline">Cancel</a>
  </div>
<% end %>

<% if new_record %>
<script>
  // Auto-slug: typing the name fills the id until the id is edited by hand.
  (function() {
    const nameField = document.getElementById('adm-name-field');
    const idField = document.getElementById('adm-id-field');
    if (!nameField || !idField) return;
    let idTouched = idField.value.length > 0;
    idField.addEventListener('input', () => { idTouched = idField.value.length > 0; });
    nameField.addEventListener('input', () => {
      if (idTouched) return;
      idField.value = nameField.value.toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '').trim().replace(/[\s_]+/g, '-').replace(/-+/g, '-');
    });
    nameField.addEventListener('change', () => { if (!idTouched) idTouched = false; });
  })();
</script>
<% end %>
