<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
  <h2 class="adm-page-title" style="margin-bottom:0;">Dashboard</h2>
  <a href="<%= admin_export_path %>" class="adm-btn adm-btn-outline">Download backup (JSON)</a>
</div>

<% cards = [
     { label: "Monuments",     key: "monuments",       hint: "Each monument gets a page + card automatically" },
     { label: "Events",        key: "events",          hint: "Each event gets a page + card automatically" },
     { label: "Experiences",   key: "experienceItems", hint: "Each experience gets a page + card automatically" },
     { label: "Hotels & Homestays", key: "accommodations", hint: "Cards on the Accommodation page" },
     { label: "News",          key: "newsItems",       hint: "News cards on the home page" },
     { label: "Cuisine",       key: "cuisineItems",    hint: "Cuisine strip on Experiences" }
   ]
   counts = @blocks.index_by(&:key) %>

<div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(230px, 1fr)); gap:14px; margin-bottom:26px;">
  <% cards.each do |c| %>
  <% block = counts[c[:key]] %>
  <a href="<%= admin_collection_path(c[:key]) %>" class="adm-card" style="display:block; text-decoration:none; color:inherit; margin-bottom:0;">
    <div style="font-size:30px; font-weight:800; color:#6e1603;"><%= block ? block.data.size : 0 %></div>
    <div style="font-weight:700; margin:2px 0 6px;"><%= c[:label] %></div>
    <div class="adm-muted" style="font-size:12px;"><%= c[:hint] %></div>
  </a>
  <% end %>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:26px;">
  <div class="adm-card" style="margin-bottom:0;">
    <h3 style="color:#6e1603; font-size:15px; margin-bottom:10px;">Edit pages</h3>
    <div style="display:flex; flex-wrap:wrap; gap:8px;">
      <a href="<%= admin_edit_section_path("homePage") %>" class="adm-btn adm-btn-outline" style="font-size:13px; padding:6px 14px;">Home</a>
      <a href="<%= admin_edit_section_path("historyPage") %>" class="adm-btn adm-btn-outline" style="font-size:13px; padding:6px 14px;">History</a>
      <a href="<%= admin_edit_section_path("monumentsPage") %>" class="adm-btn adm-btn-outline" style="font-size:13px; padding:6px 14px;">Monuments</a>
      <a href="<%= admin_edit_section_path("experiencesPage") %>" class="adm-btn adm-btn-outline" style="font-size:13px; padding:6px 14px;">Experiences</a>
      <a href="<%= admin_edit_section_path("eventsPage") %>" class="adm-btn adm-btn-outline" style="font-size:13px; padding:6px 14px;">Events</a>
      <a href="<%= admin_edit_section_path("accommodationPage") %>" class="adm-btn adm-btn-outline" style="font-size:13px; padding:6px 14px;">Accommodation</a>
      <a href="<%= admin_pages_path %>" class="adm-btn adm-btn-outline" style="font-size:13px; padding:6px 14px;">Custom pages</a>
    </div>
  </div>
  <div class="adm-card" style="margin-bottom:0;">
    <h3 style="color:#6e1603; font-size:15px; margin-bottom:10px;">Library</h3>
    <div style="display:flex; flex-wrap:wrap; gap:8px;">
      <a href="<%= admin_media_path %>" class="adm-btn adm-btn-outline" style="font-size:13px; padding:6px 14px;">Media library</a>
      <a href="<%= admin_edit_section_path("settings") %>" class="adm-btn adm-btn-outline" style="font-size:13px; padding:6px 14px;">Site settings</a>
      <a href="<%= admin_export_path %>" class="adm-btn adm-btn-outline" style="font-size:13px; padding:6px 14px;">Backup</a>
    </div>
  </div>
</div>

<details class="adm-card">
  <summary style="cursor:pointer; color:#6e1603; font-weight:600; font-size:14px;">All content sections (advanced)</summary>
  <table class="adm-table" style="margin-top:12px;">
    <thead>
      <tr><th>Section</th><th>Last updated</th><th></th></tr>
    </thead>
    <tbody>
      <% @blocks.each do |block| %>
      <tr>
        <td>
          <strong><%= key_label(block.key) %></strong>
          <div class="adm-muted" style="font-size:11px;"><%= block.key %><%= " · #{block.data.size} records" if block.data.is_a?(Array) %></div>
        </td>
        <td class="adm-muted"><%= block.updated_at.strftime("%d %b %Y, %H:%M") %></td>
        <td>
          <% if block.data.is_a?(Array) %>
            <a href="<%= admin_collection_path(block.key) %>" class="adm-btn adm-btn-outline" style="padding:5px 14px; font-size:13px;">Manage records</a>
          <% elsif block.data.is_a?(Hash) %>
            <a href="<%= admin_edit_section_path(block.key) %>" class="adm-btn adm-btn-outline" style="padding:5px 14px; font-size:13px;">Edit section</a>
          <% else %>
            <a href="<%= edit_admin_content_block_path(block.key) %>" class="adm-btn adm-btn-outline" style="padding:5px 14px; font-size:13px;">Edit</a>
          <% end %>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
</details>
