<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
  <h2 class="adm-page-title" style="margin-bottom:0;">Content</h2>
  <a href="<%= admin_export_path %>" class="adm-btn adm-btn-outline">Download backup (JSON)</a>
</div>

<div class="adm-card">
  <table class="adm-table">
    <thead>
      <tr><th>Section</th><th>Last updated</th><th></th></tr>
    </thead>
    <tbody>
      <% @blocks.each do |block| %>
      <tr>
        <td><strong><%= block.key %></strong></td>
        <td class="adm-muted"><%= block.updated_at.strftime("%d %b %Y, %H:%M") %></td>
        <td><a href="<%= edit_admin_content_block_path(block.key) %>" class="adm-btn adm-btn-outline" style="padding:5px 14px; font-size:13px;">Edit</a></td>
      </tr>
      <% end %>
    </tbody>
  </table>
</div>

<p class="adm-muted">
  <%= @blocks.size %> content sections stored in the database. Edits made here
  survive deploys; content.json is only the initial seed.
</p>
