<% title_for = ->(rec) {
     rec.is_a?(Hash) ? (rec["name"] || rec["title"] || rec["label"] || rec["id"] || rec.values.find { |v| v.is_a?(String) } || "(record)").to_s.truncate(60) : rec.to_s.truncate(60)
   }
   image_for = ->(rec) {
     rec.is_a?(Hash) ? rec.find { |k, v| media_field?(k) && v.is_a?(String) && v.present? }&.last : nil
   } %>

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:10px;">
  <h2 class="adm-page-title" style="margin-bottom:0;"><%= key_label(@key) %></h2>
  <div style="display:flex; gap:10px;">
    <a href="<%= admin_new_collection_record_path(@key) %>" class="adm-btn">+ Add <%= key_label(@key).singularize.downcase %></a>
    <a href="<%= edit_admin_content_block_path(@key) %>" class="adm-btn adm-btn-outline">Raw JSON</a>
  </div>
</div>

<div class="adm-card">
  <table class="adm-table">
    <thead>
      <tr><th style="width:56px;"></th><th>Record</th><th>Visible</th><th style="width:300px;"></th></tr>
    </thead>
    <tbody>
      <% @records.each_with_index do |rec, i| %>
      <tr>
        <td>
          <% if (img = image_for.call(rec)) %>
            <img src="<%= img %>" style="width:44px; height:44px; object-fit:cover; border-radius:8px; border:1px solid #ddd0bf;" loading="lazy" alt="">
          <% end %>
        </td>
        <td>
          <strong><%= title_for.call(rec) %></strong>
          <% if (live = live_path_for(@key, rec)) %>
            <div style="font-size:12px;"><a href="<%= live %>" target="_blank" style="color:#6e1603; text-decoration:underline;"><%= live %> ↗</a></div>
          <% elsif rec.is_a?(Hash) && rec["id"] %>
            <div class="adm-muted" style="font-size:12px;">id: <%= rec["id"] %></div>
          <% end %>
        </td>
        <td>
          <% if rec.is_a?(Hash) && rec.key?("visible") %>
            <span style="font-size:12px; padding:3px 10px; border-radius:12px; <%= rec['visible'] == false ? 'background:#f0e4e1; color:#8a1f0e;' : 'background:#e3efdd; color:#2c5424;' %>">
              <%= rec["visible"] == false ? "Hidden" : "Visible" %>
            </span>
          <% else %>
            <span class="adm-muted">—</span>
          <% end %>
        </td>
        <td style="text-align:right; white-space:nowrap;">
          <%= button_to "↑", admin_move_collection_record_path(@key, i, dir: "up"), method: :patch, style: "display:inline-block;", class: "adm-btn adm-btn-outline adm-btn-sm" %>
          <%= button_to "↓", admin_move_collection_record_path(@key, i, dir: "down"), method: :patch, style: "display:inline-block;", class: "adm-btn adm-btn-outline adm-btn-sm" %>
          <a href="<%= admin_edit_collection_record_path(@key, i) %>" class="adm-btn adm-btn-outline adm-btn-sm">Edit</a>
          <%= button_to "Delete", admin_collection_record_path(@key, i), method: :delete,
                form: { onsubmit: "return confirm('Delete this record?')" },
                style: "display:inline-block;", class: "adm-btn adm-btn-outline adm-btn-sm" %>
        </td>
      </tr>
      <% end %>
      <% if @records.empty? %>
      <tr><td colspan="4" class="adm-muted">No records yet — add the first one.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if AdminHelper::LIVE_PATHS.key?(@key) %>
<p class="adm-muted">
  Every record here automatically gets its own page at
  <code><%= AdminHelper::LIVE_PATHS[@key] %>/&lt;id&gt;</code> and a card on the listing page.
</p>
<% end %>

<style>
  .adm-btn-sm { padding: 4px 10px !important; font-size: 12px !important; }
  td form.button_to { display: inline-block; margin: 0 2px; }
</style>
