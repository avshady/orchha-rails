<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Visit Orchha — A Living Heritage of Madhya Pradesh</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta charset="UTF-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= yield :head %>
  </head>
  <body>
    <%= yield %>
    <%= render 'shared/qr_scanner' %>

    <script>
      // Mobile drawer: "Discover Orchha" expands/collapses its sub-links.
      document.addEventListener('click', function (e) {
        var btn = e.target.closest('.nav-mobile-group-btn');
        if (!btn) return;
        var group = btn.closest('.nav-mobile-group');
        var open = group.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });

      // Auto-hide the nav on every page: visible briefly on load, then
      // tucked away — reveal by moving the cursor to the top edge or
      // hovering the bar. Pointer-only, so touch devices keep it visible.
      (function () {
        // Outermost fixed wrapper on scroll-jack pages; otherwise the
        // in-flow bar (home .navbar / listing pages' .hist-navbar).
        var nav = document.querySelector('.mdet-nav-wrap, .lss-nav-fixed') ||
                  document.querySelector('.navbar, .hist-navbar');
        if (!nav) return;
        if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
        // Never auto-hide at mobile widths — the bar stays pinned there.
        if (window.matchMedia('(max-width: 900px)').matches) return;

        var REVEAL_ZONE = 110;   // px from top that reveals the bar
        var HIDE_DELAY  = 1600;  // ms after the cursor leaves before tucking away
        var hideTimer = null, hovering = 0;

        function show() { clearTimeout(hideTimer); nav.classList.remove('nav-autohidden'); }
        function scheduleHide() {
          clearTimeout(hideTimer);
          hideTimer = setTimeout(function () { if (!hovering) nav.classList.add('nav-autohidden'); }, HIDE_DELAY);
        }

        window.addEventListener('mousemove', function (e) {
          if (e.clientY <= REVEAL_ZONE) show();
          else if (!hovering) scheduleHide();
        }, { passive: true });

        // The Discover dropdown lives outside the bar — count it as part of
        // the hover region so the nav doesn't tuck away mid-navigation.
        var regions = [nav];
        document.querySelectorAll('.nav-dropdown, .hist-nav-dropdown, .mdet-nav-dd').forEach(function (dd) { regions.push(dd); });
        regions.forEach(function (el) {
          el.addEventListener('mouseenter', function () { hovering++; show(); });
          el.addEventListener('mouseleave', function () { hovering = Math.max(0, hovering - 1); scheduleHide(); });
          el.addEventListener('focusin', show);
          el.addEventListener('focusout', scheduleHide);
        });

        // Show on load, then tuck away after a beat.
        show();
        hideTimer = setTimeout(function () { if (!hovering) nav.classList.add('nav-autohidden'); }, 2200);
      })();
    </script>
    <script>
      // ── Fit long monument names: if a single unbreakable word overflows
      // the heading column, step the font size down until it fits. ──
      (function () {
        function fit() {
          document.querySelectorAll('.mdet-name').forEach(function (el) {
            el.style.fontSize = '';
            var size = parseFloat(getComputedStyle(el).fontSize);
            var guard = 0;
            while (size > 38 && el.scrollWidth > el.clientWidth + 1 && guard < 20) {
              size -= 2;
              el.style.fontSize = size + 'px';
              guard++;
            }
          });
        }
        fit();
        if (document.fonts && document.fonts.ready) document.fonts.ready.then(fit);
        window.addEventListener('resize', fit);
      })();
    </script>
    <script>
      // ── Video sound: try to start heroes with sound; when the browser
      // blocks unmuted autoplay, stay muted and offer a one-tap speaker. ──
      (function () {
        var ICON_ON  = '<svg viewBox="0 0 24 24" fill="none"><path d="M11 5 6.5 9H3v6h3.5L11 19V5Z" fill="currentColor"/><path d="M15 9c1 .8 1.6 1.8 1.6 3S16 14.2 15 15M17.5 6.5C19.4 8 20.5 9.9 20.5 12s-1.1 4-3 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>';
        var ICON_OFF = '<svg viewBox="0 0 24 24" fill="none"><path d="M11 5 6.5 9H3v6h3.5L11 19V5Z" fill="currentColor"/><path d="m15.5 9.5 5 5m0-5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>';

        function setup(v) {
          var host = v.parentElement;
          if (!host) return;
          if (getComputedStyle(host).position === 'static') host.style.position = 'relative';
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'video-sound-btn';
          btn.setAttribute('aria-label', 'Toggle sound');
          function paint() { btn.innerHTML = v.muted ? ICON_OFF : ICON_ON; }
          btn.addEventListener('click', function (e) {
            e.preventDefault(); e.stopPropagation();
            v.muted = !v.muted;
            if (!v.muted) { v.volume = 1; v.play().catch(function () {}); }
            paint();
          });
          host.appendChild(btn);

          // attempt sound-on playback straight away
          v.muted = false;
          var attempt = v.play();
          if (attempt && attempt.catch) {
            attempt.then(paint).catch(function () {
              v.muted = true;              // browser refused sound — stay silent
              v.play().catch(function () {});
              paint();
            });
          } else {
            paint();
          }
        }

        document.querySelectorAll('video[data-sound-video]').forEach(setup);
      })();
    </script>
  </body>
</html>
