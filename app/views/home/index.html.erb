      <path d="M0,0 L520,0 C580,0 660,80 720,80 C780,80 860,0 920,0 L1440,0 L1440,100 L0,100 Z" fill="#e7ded5"/>
    </svg>
  </div>
</section>

<% if slides.size > 1 %>
<script>
(function() {
  const IMAGE_DURATION = 6000;
  const FADE_MS        = 900;

  const slideEls = Array.from(document.querySelectorAll('.hero-slide'));
  const dotEls   = Array.from(document.querySelectorAll('.hero-dot'));
  let current    = 0;
  let timer      = null;

  function goTo(idx) {
    slideEls[current].classList.remove('active');
    if (dotEls[current]) dotEls[current].classList.remove('active');
    current = (idx + slideEls.length) % slideEls.length;
    slideEls[current].classList.add('active');
    if (dotEls[current]) dotEls[current].classList.add('active');
    scheduleNext();
  }

  function scheduleNext() {
    clearTimeout(timer);
    const media = slideEls[current].querySelector('video');
    if (media) {
      media.currentTime = 0;
      media.play().catch(() => {});
      media.onended = () => goTo(current + 1);
      timer = setTimeout(() => goTo(current + 1), 30000); // safety cap 30s
    } else {
      timer = setTimeout(() => goTo(current + 1), IMAGE_DURATION);
    }
  }

  dotEls.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

  // Pause on first video if already loaded
  const firstVideo = slideEls[0].querySelector('video');
  if (firstVideo) {
    firstVideo.onended = () => goTo(1);
    timer = setTimeout(() => goTo(1), 30000);
  } else {
    timer = setTimeout(() => goTo(1), IMAGE_DURATION);
  }
})();
</script>
<% end %>

