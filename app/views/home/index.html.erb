<script>
  document.querySelectorAll('.news-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.news-filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  // Discover Orchha dropdown — position: fixed so it escapes all stacking contexts
  const discoverBtn = document.querySelector('.nav-discover-btn');
  const discoverDropdown = document.querySelector('.nav-dropdown');
  if (discoverBtn && discoverDropdown) {
    let discoverCloseTimer;
    function openDropdown() {
      clearTimeout(discoverCloseTimer);
      const r = discoverBtn.getBoundingClientRect();
      discoverDropdown.style.top  = (r.bottom + 8) + 'px';
      discoverDropdown.style.left = r.left + 'px';
      discoverDropdown.classList.add('open');
      discoverBtn.classList.add('open');
      discoverBtn.setAttribute('aria-expanded', 'true');
    }
    function closeDropdown() {
      discoverDropdown.classList.remove('open');
      discoverBtn.classList.remove('open');
      discoverBtn.setAttribute('aria-expanded', 'false');
    }
    function scheduleCloseDropdown() { discoverCloseTimer = setTimeout(closeDropdown, 200); }
    discoverBtn.addEventListener('mouseenter', openDropdown);
    discoverBtn.addEventListener('mouseleave', scheduleCloseDropdown);
    discoverDropdown.addEventListener('mouseenter', () => clearTimeout(discoverCloseTimer));
    discoverDropdown.addEventListener('mouseleave', scheduleCloseDropdown);
    // Touch/keyboard fallback: first activation opens the menu instead of navigating;
    // activating again (dropdown already open) lets the link follow through to "/"
    discoverBtn.addEventListener('click', function(e) {
      if (discoverDropdown.classList.contains('open')) return;
      e.preventDefault();
      openDropdown();
    });
    document.addEventListener('click', closeDropdown);
    discoverDropdown.addEventListener('click', function(e) { e.stopPropagation(); });
  }

  // Mobile hamburger menu
  const navHamburgerBtn = document.getElementById('nav-hamburger-btn');
  const navMobileMenu   = document.getElementById('nav-mobile-menu');
  const navMobileClose  = document.getElementById('nav-mobile-close-btn');
  if (navHamburgerBtn && navMobileMenu) {
    function openMobileMenu() {
      navMobileMenu.classList.add('open');
      navHamburgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMobileMenu() {
      navMobileMenu.classList.remove('open');
      navHamburgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    navHamburgerBtn.addEventListener('click', openMobileMenu);
    if (navMobileClose) navMobileClose.addEventListener('click', closeMobileMenu);
    navMobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMobileMenu));
  }
</script>
