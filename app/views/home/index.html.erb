<%# ── HERO ───────────────────────────────────────────── %>
<% hero   = @page['hero'] || {}
   slides = hero['slides'] || []
   slides = [{'type'=>'image','src'=>'/images/hero_bg.jpg'}] if slides.empty? %>
<section class="hero">
  <%# Carousel slides — stacked, crossfade via opacity %>
  <div class="hero-slides" data-slide-count="<%= slides.size %>">
    <% slides.each_with_index do |slide, i| %>
    <div class="hero-slide<%= i == 0 ? ' active' : '' %>" data-index="<%= i %>">
      <% if slide['type'] == 'video' %>
      <% ext = File.extname(slide['src'].to_s.split('?').first.to_s).delete('.').presence %>
      <video class="hero-slide-media" autoplay muted playsinline preload="auto">
        <source src="<%= slide['src'] %>" <%= "type=\"video/#{ext == 'mov' ? 'mp4' : ext}\"".html_safe if ext %>>
      </video>
      <% else %>
      <img class="hero-slide-media" src="<%= slide['src'] %>" alt="Orchha">
      <% end %>
    </div>
    <% end %>
  </div>
  <div class="hero-overlay"></div>

  <%# Dot indicators — only shown when more than one slide %>
  <% if slides.size > 1 %>
  <div class="hero-dots">
    <% slides.each_with_index do |_, i| %>
    <button class="hero-dot<%= i == 0 ? ' active' : '' %>" data-target="<%= i %>" aria-label="Slide <%= i + 1 %>"></button>
    <% end %>
  </div>
  <% end %>

  <div class="hero-wrap">
    <%# Nav %>
    <% nav = @page['nav'] || {}; dd = nav['discoverDropdown'] || [] %>
    <nav class="navbar">
      <div class="nav-links">
        <div class="nav-discover">
          <a href="/" class="nav-link nav-discover-btn" aria-expanded="false" aria-haspopup="true">
            Discover Orchha
            <svg viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <a href="/plan-your-visit" class="nav-link">Plan Your Visit</a>
        <a href="/news" class="nav-link">News</a>
        <a href="/support-us" class="nav-link">Support Us</a>
        <a href="/sabhyata" class="nav-link">Sabhyata Foundation</a>
      </div>
      <button class="nav-hamburger" id="nav-hamburger-btn" aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="https://www.tezticket.com/tickets/buy?event=SF" target="_blank" rel="noopener" class="nav-book-btn">Book Tickets</a>
    </nav>

    <%# Hero Content %>
    <div class="hero-content">
      <div class="hero-content-glow"></div>
      <div class="hero-title-row">
        <h1 class="hero-title"><%= hero['heading'].present? ? hero['heading'] : 'Orchha' %></h1>
        <div class="hero-subtitle-block">
          <div class="hero-divider"></div>
          <p class="hero-subtitle"><%= hero['subtitle'].present? ? hero['subtitle'] : 'A Living Heritage of Madhya Pradesh, Where History Breathes in Every Stone' %></p>
        </div>
      </div>
    </div>

    <%# Hero Footer %>
    <div class="hero-footer">
      <div class="hero-mpt-wrap">
        <img src="/images/mpt_logo.png" alt="MPT" class="hero-mpt-logo">
      </div>
      <div class="hero-btn-group">
        <a href="<%= hero['ctaLink'].present? ? hero['ctaLink'] : '/monuments' %>" class="hero-explore-btn"><%= hero['ctaText'].present? ? hero['ctaText'] : 'Explore Monuments' %></a>
      </div>
      <div class="hero-india-wrap">
        <img src="/images/incredible_india.png" alt="Incredible India" class="hero-india-logo">
      </div>
    </div>
  </div>

  <%# Discover dropdown — kept outside .hero-wrap (transform:translateX) and
      .navbar (backdrop-filter), both of which create a new containing block
      for position:fixed descendants and would trap the dropdown off-position %>
  <div class="nav-dropdown" role="menu">
    <% dd.each do |item| %>
    <a href="<%= item['url'] %>" class="nav-dropdown-item" role="menuitem"><%= item['label'] %></a>
    <% end %>
